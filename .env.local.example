# 本地开发环境配置
# 复制此文件为 .env.local 并修改

# 会话密钥（必须设置，用于 session 加密）
SESSION_SECRET=your-local-secret-key-change-me

# 加密密钥（Redis 必须设置）
# CRYPTO_SECRET=your-crypto-secret-key

# 数据库配置（可选，默认使用 SQLite）
# MySQL 示例:
# SQL_DSN=root:password@tcp(127.0.0.1:3306)/newapi?parseTime=true
# PostgreSQL 示例:
# SQL_DSN=postgres://user:password@localhost:5432/newapi

# Redis 配置（可选）
# REDIS_CONN_STRING=redis://localhost:6379/0

# 端口号（默认 3000）
# PORT=3000

# 调试模式
# DEBUG=true
# ENABLE_PPROF=true
