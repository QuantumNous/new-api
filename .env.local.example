# ============================================================
# aikanhub local dev environment
# 复制为 .env.local 后填好下面 TODO 项即可。
# 这个文件已在 .gitignore 里，不要提交。
# ============================================================

# --- 数据库（Neon PostgreSQL）---
# 操作步骤：
#   1. 登录 https://console.neon.tech 创建一个 project
#   2. 进入 project → Connection Details
#   3. ⚠️ 选择 "Direct connection"（不要选 Pooled connection），避免 GORM prepared statement 与 PgBouncer 冲突
#   4. 复制完整连接串粘贴到下面，格式形如：
#        postgresql://<user>:<password>@ep-xxxx-xxxx.<region>.aws.neon.tech/<dbname>?sslmode=require
SQL_DSN=TODO_PASTE_NEON_DIRECT_CONNECTION_STRING_HERE

# Neon 免费层 scale-to-zero，首请求 ~1s 冷启动。
# 上线前升 Launch ($19/月) 关掉 auto-suspend。

# --- Redis（本地 Docker）---
# 这个值要和 docker-compose.local.yml 里的密码一致。已经预填好，无需修改。
REDIS_CONN_STRING=redis://:3070f09bd424ef9d1bedd3e035616fd7@redis:6379

# --- 会话密钥 ---
# 已生成随机值，无需修改。多机部署时所有节点必须用同一个值。
SESSION_SECRET=daf477b4e94c38c983ff5f4268a5fa6d5fa3be4e6277d7c8bc61476d33393a42

# --- 通用配置 ---
TZ=Asia/Shanghai
PORT=3000
ERROR_LOG_ENABLED=true
BATCH_UPDATE_ENABLED=true
NODE_NAME=aikanhub-dev-1

# --- 视频任务相关（Seedance 走异步任务，建议开）---
# 任务调度器（轮询上游任务状态）
UPDATE_TASK=true
# 流式请求超时（视频生成不是流式，但 chat 类上游会用）
STREAMING_TIMEOUT=300

# --- 调试（按需打开）---
# DEBUG=true
# ENABLE_PPROF=true
