# 测试环境配置模板 — 单容器 PostgreSQL + Redis
#
# 使用方式：
#   cp .env.test.example .env.test
#   docker compose --profile local --env-file .env.test up -d
#
# 说明：
#   postgres 和 redis 容器通过 profiles: [local] 激活，仅测试环境启动
#   本文件提交到 git；.env.test 本身不提交（已加入 .gitignore）

# PostgreSQL（容器服务名 postgres，仅在 --profile local 下启动）
SQL_DSN=postgresql://root:changeme@postgres:5432/new-api

# Redis（容器服务名 redis）
# 密码必须与 REDIS_PASSWORD 一致
REDIS_CONN_STRING=redis://:changeme@redis:6379

# postgres 容器密码（供 postgres 容器的 POSTGRES_PASSWORD 使用，与 SQL_DSN 中一致）
POSTGRES_PASSWORD=changeme

# Redis 容器密码（供 redis 容器的 --requirepass 使用，与 REDIS_CONN_STRING 中一致）
REDIS_PASSWORD=changeme

# Session 密钥（测试环境可随意填写）
SESSION_SECRET=dev-session-secret-do-not-use-in-prod

# Watchtower 令牌（测试环境可随意填写）
WATCHTOWER_API_TOKEN=dev-watchtower-token

# 节点名
NODE_NAME=new-api-dev

# KYC 加密 key（AES-256-GCM）— 测试环境固定值，保持与 .env.local 一致方便数据互通
# 生产环境必须用 openssl rand -hex 32 生成独立 key
KYC_ENCRYPT_KEY=00000000000000000000000000000000000000000000000000000000deadbeef
KYC_HASH_KEY=00000000000000000000000000000000000000000000000000000000cafebabe
