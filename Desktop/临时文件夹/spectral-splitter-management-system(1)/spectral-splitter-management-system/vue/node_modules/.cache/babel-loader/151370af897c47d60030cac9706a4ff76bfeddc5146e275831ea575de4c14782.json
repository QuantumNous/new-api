{"ast":null,"code":"export default {\n  name: \"Orders\",\n  data() {\n    return {\n      user: JSON.parse(sessionStorage.getItem('sys-user') || '{}'),\n      tableData: [],\n      pageNum: 1,\n      pageSize: 10,\n      total: 0,\n      orderSn: null,\n      equipments: [],\n      users: [],\n      iams: [],\n      fromVisible: false,\n      form: {},\n      ids: [],\n      rules: {\n        equipmentId: [{\n          required: true,\n          message: '必填',\n          trigger: 'blur'\n        }],\n        content: [{\n          required: true,\n          message: '必填',\n          trigger: 'blur'\n        }]\n      }\n    };\n  },\n  created() {\n    this.load(1);\n  },\n  methods: {\n    load(pageNum) {\n      if (pageNum) this.pageNum = pageNum;\n      this.$request.get('/orders/selectPage', {\n        params: {\n          pageNum: this.pageNum,\n          pageSize: this.pageSize,\n          orderSn: this.orderSn\n        }\n      }).then(res => {\n        this.tableData = res.data?.list;\n        this.total = res.data?.total;\n      });\n      this.$request.get('/equipment/selectAll').then(res => {\n        this.equipments = res.data;\n      });\n      this.$request.get('/user/selectAll').then(res => {\n        this.users = res.data;\n      });\n      this.$request.get('/iam/selectAll').then(res => {\n        this.iams = res.data;\n      });\n    },\n    reset() {\n      this.orderSn = null;\n      this.load(1);\n    },\n    handleAdd() {\n      this.form = {\n        state: 1\n      };\n      this.fromVisible = true;\n    },\n    handleEdit(row) {\n      this.form = JSON.parse(JSON.stringify(row));\n      this.fromVisible = true;\n    },\n    save() {\n      this.$refs.formRef.validate(valid => {\n        if (valid) {\n          this.$request({\n            url: this.form.id ? '/orders/update' : '/orders/add',\n            method: this.form.id ? 'PUT' : 'POST',\n            data: this.form\n          }).then(res => {\n            if (res.code === '200') {\n              this.$message.success('保存成功');\n              this.load(1);\n              this.fromVisible = false;\n            } else {\n              this.$message.error(res.msg);\n            }\n          });\n        }\n      });\n    },\n    del(id) {\n      this.$confirm('您确定删除吗？', '确认删除', {\n        type: \"warning\"\n      }).then(response => {\n        this.$request.delete('/orders/delete/' + id).then(res => {\n          if (res.code === '200') {\n            this.$message.success('操作成功');\n            this.load(1);\n          } else {\n            this.$message.error(res.msg);\n          }\n        });\n      }).catch(() => {});\n    },\n    delBatch() {\n      if (!this.ids.length) {\n        this.$message.warning('请选择数据');\n        return;\n      }\n      this.$confirm('您确定批量删除这些数据吗？', '确认删除', {\n        type: \"warning\"\n      }).then(response => {\n        this.$request.delete('/orders/delete/batch', {\n          data: this.ids\n        }).then(res => {\n          if (res.code === '200') {\n            this.$message.success('操作成功');\n            this.load(1);\n          } else {\n            this.$message.error(res.msg);\n          }\n        });\n      }).catch(() => {});\n    },\n    handleSelectionChange(rows) {\n      this.ids = rows.map(v => v.id);\n    },\n    handleCurrentChange(pageNum) {\n      this.load(pageNum);\n    },\n    sendCenter(id) {\n      this.$request({\n        url: '/orders/sendCenter/' + id,\n        method: 'GET'\n      }).then(res => {\n        if (res.code === '200') {\n          this.$message.success('发送成功');\n          this.load(1);\n          this.fromVisible = false;\n        } else {\n          this.$message.error(res.msg);\n        }\n      });\n    }\n  }\n};","map":{"version":3,"names":["name","data","user","JSON","parse","sessionStorage","getItem","tableData","pageNum","pageSize","total","orderSn","equipments","users","iams","fromVisible","form","ids","rules","equipmentId","required","message","trigger","content","created","load","methods","$request","get","params","then","res","list","reset","handleAdd","state","handleEdit","row","stringify","save","$refs","formRef","validate","valid","url","id","method","code","$message","success","error","msg","del","$confirm","type","response","delete","catch","delBatch","length","warning","handleSelectionChange","rows","map","v","handleCurrentChange","sendCenter"],"sources":["src/views/manager/Orders.vue"],"sourcesContent":["<template>\r\n  <div>\r\n    <div class=\"search\">\r\n      <el-input placeholder=\"查询工单\" style=\"width: 200px;\" v-model=\"orderSn\"></el-input>\r\n      <el-button type=\"info\" plain style=\"margin-left: 10px;\" @click=\"load(1)\">查询</el-button>\r\n      <el-button type=\"warning\" plain style=\"margin-left: 10px;\" @click=\"reset\">重置</el-button>\r\n    </div>\r\n\r\n    <div class=\"operation\">\r\n      <el-button type=\"danger\" plain @click=\"delBatch\">批量删除</el-button>\r\n    </div>\r\n\r\n    <div class=\"table\">\r\n      <el-table :data=\"tableData\" stripe @selection-change=\"handleSelectionChange\">\r\n        <el-table-column type=\"selection\" width=\"55\" align=\"center\"></el-table-column>\r\n        <el-table-column type=\"expand\" label=\"工单内容\" width=\"120\">\r\n          <template slot-scope=\"scope\" >\r\n            <div v-if=\"scope.row.subOrdersList.length > 0\">\r\n              <div v-for=\"(item,index) in scope.row.subOrdersList\" :key=\"index\"\r\n                   style=\"display: flex;margin: 10px 0;font-size: 16px;align-items: center\">\r\n                <div style=\"width: 200px\">客户：{{ item?.customer?.name }}</div>\r\n                <div style=\"width: 300px\">客户经理：{{ item?.user?.name }}</div>\r\n                <div style=\"width: 300px\">割接时间：{{ item?.repairTime }}</div>\r\n                <div style=\"width: 300px\">装维：{{ item?.user?.name }}</div>\r\n                <div style=\"flex: 1\">装维反馈：{{ item?.iamContent }}</div>\r\n                <div style=\"width: 200px\">\r\n                  <el-button type=\"danger\" plain >删除</el-button>\r\n                </div>\r\n              </div>\r\n            </div>\r\n            <el-empty v-else description=\"没有客户\"></el-empty>\r\n          </template>\r\n        </el-table-column>\r\n        <el-table-column prop=\"orderSn\" label=\"工单号\"></el-table-column>\r\n        <el-table-column prop=\"equipment.oltCode\" label=\"分光器\"></el-table-column>\r\n        <el-table-column prop=\"startTime\" label=\"开始时间\"></el-table-column>\r\n        <el-table-column prop=\"state\" label=\"状态\">\r\n          <template slot-scope=\"scope\" >\r\n            <el-tag type=\"warning\" v-if=\"scope.row.state === 1\">进行中</el-tag>\r\n            <el-tag type=\"danger\" v-if=\"scope.row.state === 2\">已完成</el-tag>\r\n            <el-tag type=\"info\" v-if=\"scope.row.state === 3\">已发送到资源中心</el-tag>\r\n          </template>\r\n        </el-table-column>\r\n        <el-table-column label=\"操作\" width=\"250\" align=\"center\">\r\n          <template v-slot=\"scope\">\r\n            <el-button plain type=\"info\" @click=\"sendCenter(scope.row.id)\" size=\"mini\" v-if=\"scope.row.state === 2\">发送</el-button>\r\n            <el-button plain type=\"primary\" @click=\"handleEdit(scope.row)\" size=\"mini\">编辑</el-button>\r\n            <el-button plain type=\"danger\" size=\"mini\" @click=del(scope.row.id)>删除</el-button>\r\n          </template>\r\n        </el-table-column>\r\n      </el-table>\r\n\r\n      <div class=\"pagination\">\r\n        <el-pagination\r\n            background\r\n            @current-change=\"handleCurrentChange\"\r\n            :current-page=\"pageNum\"\r\n            :page-sizes=\"[5, 10, 20]\"\r\n            :page-size=\"pageSize\"\r\n            layout=\"total, prev, pager, next\"\r\n            :total=\"total\">\r\n        </el-pagination>\r\n      </div>\r\n    </div>\r\n\r\n    <el-dialog title=\"工单信息\" :visible.sync=\"fromVisible\" width=\"40%\" :close-on-click-modal=\"false\" destroy-on-close>\r\n      <el-form label-width=\"100px\" style=\"padding-right: 50px\" :model=\"form\" :rules=\"rules\" ref=\"formRef\">\r\n        <el-form-item prop=\"equipmentId\" label=\"分光器\">\r\n          <el-select v-model=\"form.equipmentId\" style=\"width: 300px\">\r\n            <el-option v-for=\"(item,index) in equipments\" :key=\"index\" :label=\"item.code\" :value=\"item.id\">\r\n            </el-option>\r\n          </el-select>\r\n        </el-form-item>\r\n        <el-form-item prop=\"userId\" label=\"客户经理\">\r\n          <el-select v-model=\"form.userId\" style=\"width: 300px\">\r\n            <el-option v-for=\"(item,index) in users\" :key=\"index\" :label=\"item.name\" :value=\"item.id\">\r\n            </el-option>\r\n          </el-select>\r\n        </el-form-item>\r\n        <el-form-item prop=\"iamId\" label=\"装维\">\r\n          <el-select v-model=\"form.iamId\" style=\"width: 300px\">\r\n            <el-option v-for=\"(item,index) in iams\" :key=\"index\" :label=\"item.name\" :value=\"item.id\">\r\n            </el-option>\r\n          </el-select>\r\n        </el-form-item>\r\n        <el-form-item prop=\"content\" label=\"工单内容\">\r\n          <el-input v-model=\"form.content\" type=\"textarea\" autosize autocomplete=\"off\"></el-input>\r\n        </el-form-item>\r\n      </el-form>\r\n      <div slot=\"footer\" class=\"dialog-footer\">\r\n        <el-button @click=\"fromVisible = false\">取 消</el-button>\r\n        <el-button type=\"primary\" @click=\"save\">确 定</el-button>\r\n      </div>\r\n    </el-dialog>\r\n\r\n  </div>\r\n</template>\r\n\r\n\r\n<script>\r\nexport default {\r\n  name: \"Orders\",\r\n  data() {\r\n    return {\r\n      user: JSON.parse(sessionStorage.getItem('sys-user') || '{}'),\r\n\r\n      tableData: [],\r\n      pageNum: 1,\r\n      pageSize: 10,\r\n      total: 0,\r\n\r\n      orderSn: null,\r\n\r\n      equipments: [],\r\n      users: [],\r\n      iams: [],\r\n\r\n      fromVisible: false,\r\n      form: {},\r\n      ids: [],\r\n\r\n      rules: {\r\n        equipmentId: [{required: true, message: '必填', trigger: 'blur'},],\r\n        content: [{required: true, message: '必填', trigger: 'blur'},]\r\n      },\r\n    }\r\n  },\r\n  created() {\r\n    this.load(1)\r\n  },\r\n  methods: {\r\n    load(pageNum) {\r\n      if (pageNum) this.pageNum = pageNum\r\n      this.$request.get('/orders/selectPage', {\r\n        params: {\r\n          pageNum: this.pageNum,\r\n          pageSize: this.pageSize,\r\n          orderSn: this.orderSn,\r\n        }\r\n      }).then(res => {\r\n        this.tableData = res.data?.list\r\n        this.total = res.data?.total\r\n      })\r\n\r\n      this.$request.get('/equipment/selectAll').then(res => {\r\n        this.equipments = res.data\r\n      })\r\n      this.$request.get('/user/selectAll').then(res => {\r\n        this.users = res.data\r\n      })\r\n      this.$request.get('/iam/selectAll').then(res => {\r\n        this.iams = res.data\r\n      })\r\n\r\n    },\r\n    reset() {\r\n      this.orderSn = null\r\n      this.load(1)\r\n    },\r\n    handleAdd() {\r\n      this.form = {\r\n        state: 1\r\n      }\r\n      this.fromVisible = true\r\n    },\r\n    handleEdit(row) {\r\n      this.form = JSON.parse(JSON.stringify(row))\r\n      this.fromVisible = true\r\n    },\r\n    save() {\r\n      this.$refs.formRef.validate((valid) => {\r\n        if (valid) {\r\n          this.$request({\r\n            url: this.form.id ? '/orders/update' : '/orders/add',\r\n            method: this.form.id ? 'PUT' : 'POST',\r\n            data: this.form\r\n          }).then(res => {\r\n            if (res.code === '200') {\r\n              this.$message.success('保存成功')\r\n              this.load(1)\r\n              this.fromVisible = false\r\n            } else {\r\n              this.$message.error(res.msg)\r\n            }\r\n          })\r\n        }\r\n      })\r\n    },\r\n    del(id) {\r\n      this.$confirm('您确定删除吗？', '确认删除', {type: \"warning\"}).then(response => {\r\n        this.$request.delete('/orders/delete/' + id).then(res => {\r\n          if (res.code === '200') {\r\n            this.$message.success('操作成功')\r\n            this.load(1)\r\n          } else {\r\n            this.$message.error(res.msg)\r\n          }\r\n        })\r\n      }).catch(() => {\r\n      })\r\n    },\r\n    delBatch() {\r\n      if (!this.ids.length) {\r\n        this.$message.warning('请选择数据')\r\n        return\r\n      }\r\n      this.$confirm('您确定批量删除这些数据吗？', '确认删除', {type: \"warning\"}).then(response => {\r\n        this.$request.delete('/orders/delete/batch', {data: this.ids}).then(res => {\r\n          if (res.code === '200') {\r\n            this.$message.success('操作成功')\r\n            this.load(1)\r\n          } else {\r\n            this.$message.error(res.msg)\r\n          }\r\n        })\r\n      }).catch(() => {\r\n      })\r\n    },\r\n    handleSelectionChange(rows) {\r\n      this.ids = rows.map(v => v.id)\r\n    },\r\n    handleCurrentChange(pageNum) {\r\n      this.load(pageNum)\r\n    },\r\n    sendCenter(id) {\r\n      this.$request({\r\n        url: '/orders/sendCenter/' + id,\r\n        method: 'GET',\r\n      }).then(res => {\r\n        if (res.code === '200') {\r\n          this.$message.success('发送成功')\r\n          this.load(1)\r\n          this.fromVisible = false\r\n        } else {\r\n          this.$message.error(res.msg)\r\n        }\r\n      })\r\n    },\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n\r\n</style>"],"mappings":"AAoGA;EACAA,IAAA;EACAC,KAAA;IACA;MACAC,IAAA,EAAAC,IAAA,CAAAC,KAAA,CAAAC,cAAA,CAAAC,OAAA;MAEAC,SAAA;MACAC,OAAA;MACAC,QAAA;MACAC,KAAA;MAEAC,OAAA;MAEAC,UAAA;MACAC,KAAA;MACAC,IAAA;MAEAC,WAAA;MACAC,IAAA;MACAC,GAAA;MAEAC,KAAA;QACAC,WAAA;UAAAC,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA;QACAC,OAAA;UAAAH,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA;MACA;IACA;EACA;EACAE,QAAA;IACA,KAAAC,IAAA;EACA;EACAC,OAAA;IACAD,KAAAjB,OAAA;MACA,IAAAA,OAAA,OAAAA,OAAA,GAAAA,OAAA;MACA,KAAAmB,QAAA,CAAAC,GAAA;QACAC,MAAA;UACArB,OAAA,OAAAA,OAAA