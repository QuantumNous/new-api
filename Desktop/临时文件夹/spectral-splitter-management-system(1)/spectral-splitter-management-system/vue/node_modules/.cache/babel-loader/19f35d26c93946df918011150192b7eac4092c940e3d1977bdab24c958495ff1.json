{"ast":null,"code":"export default {\n  name: \"UserOrders\",\n  data() {\n    return {\n      user: JSON.parse(sessionStorage.getItem('sys-user') || '{}'),\n      tableData: [],\n      pageNum: 1,\n      pageSize: 10,\n      total: 0,\n      orderSn: null,\n      fromVisible: false,\n      form: {},\n      rules: {\n        repairTime: [{\n          required: true,\n          message: '必填',\n          trigger: 'blur'\n        }]\n      }\n    };\n  },\n  created() {\n    this.load(1);\n  },\n  methods: {\n    load(pageNum) {\n      if (pageNum) this.pageNum = pageNum;\n      this.$request.get('/orders/selectPage', {\n        params: {\n          pageNum: this.pageNum,\n          pageSize: this.pageSize,\n          orderSn: this.orderSn,\n          userId: this.user.id\n        }\n      }).then(res => {\n        this.tableData = res.data?.list;\n        this.total = res.data?.total;\n      });\n    },\n    reset() {\n      this.title = null;\n      this.load(1);\n    },\n    handleEdit(row) {\n      this.form = JSON.parse(JSON.stringify(row));\n      this.fromVisible = true;\n    },\n    save() {\n      this.$refs.formRef.validate(valid => {\n        if (valid) {\n          this.form.state = 2;\n          this.$request({\n            url: '/orders/update',\n            method: 'PUT',\n            data: this.form\n          }).then(res => {\n            if (res.code === '200') {\n              this.$message.success('保存成功');\n              this.load(1);\n              this.fromVisible = false;\n            } else {\n              this.$message.error(res.msg);\n            }\n          });\n        }\n      });\n    },\n    handleCurrentChange(pageNum) {\n      this.load(pageNum);\n    }\n  }\n};","map":{"version":3,"names":["name","data","user","JSON","parse","sessionStorage","getItem","tableData","pageNum","pageSize","total","orderSn","fromVisible","form","rules","repairTime","required","message","trigger","created","load","methods","$request","get","params","userId","id","then","res","list","reset","title","handleEdit","row","stringify","save","$refs","formRef","validate","valid","state","url","method","code","$message","success","error","msg","handleCurrentChange"],"sources":["src/views/manager/UserOrders.vue"],"sourcesContent":["<template>\r\n  <div>\r\n    <div class=\"search\">\r\n      <el-input placeholder=\"查询工单\" style=\"width: 200px;\" v-model=\"orderSn\"></el-input>\r\n      <el-button type=\"info\" plain style=\"margin-left: 10px;\" @click=\"load(1)\">查询</el-button>\r\n      <el-button type=\"warning\" plain style=\"margin-left: 10px;\" @click=\"reset\">重置</el-button>\r\n    </div>\r\n\r\n    <div class=\"table\">\r\n      <el-table :data=\"tableData\" stripe>\r\n        <el-table-column type=\"expand\" label=\"工单内容\" width=\"120\">\r\n          <template slot-scope=\"scope\" prop=\"content\">\r\n            <el-card>\r\n              {{ scope.row.content }}\r\n            </el-card>\r\n          </template>\r\n        </el-table-column>\r\n        <el-table-column prop=\"orderSn\" label=\"工单号\"></el-table-column>\r\n        <el-table-column prop=\"equipment.code\" label=\"分光器\"></el-table-column>\r\n        <el-table-column prop=\"user.name\" label=\"客户经理\"></el-table-column>\r\n        <el-table-column prop=\"iam.name\" label=\"装维\"></el-table-column>\r\n        <el-table-column prop=\"startTime\" label=\"开始时间\"></el-table-column>\r\n        <el-table-column prop=\"repairTime\" label=\"割接时间\"></el-table-column>\r\n        <el-table-column prop=\"iamContent\" label=\"装维反馈\"></el-table-column>\r\n        <el-table-column prop=\"endTime\" label=\"结束时间\"></el-table-column>\r\n        <el-table-column prop=\"state\" label=\"状态\">\r\n          <template slot-scope=\"scope\" >\r\n            <el-tag type=\"warning\" v-if=\"scope.row.state === 1\">待反馈</el-tag>\r\n            <el-tag type=\"danger\" v-if=\"scope.row.state === 2\">待维修</el-tag>\r\n            <el-tag type=\"success\" v-if=\"scope.row.state === 3\">已完成</el-tag>\r\n            <el-tag type=\"info\" v-if=\"scope.row.state === 4\">已发送到资源中心</el-tag>\r\n          </template>\r\n        </el-table-column>\r\n        <el-table-column label=\"操作\" width=\"180\" align=\"center\">\r\n          <template v-slot=\"scope\">\r\n            <el-button plain type=\"primary\" @click=\"handleEdit(scope.row)\" size=\"mini\" v-if=\"scope.row.state === 1\">反馈</el-button>\r\n          </template>\r\n        </el-table-column>\r\n      </el-table>\r\n\r\n      <div class=\"pagination\">\r\n        <el-pagination\r\n            background\r\n            @current-change=\"handleCurrentChange\"\r\n            :current-page=\"pageNum\"\r\n            :page-sizes=\"[5, 10, 20]\"\r\n            :page-size=\"pageSize\"\r\n            layout=\"total, prev, pager, next\"\r\n            :total=\"total\">\r\n        </el-pagination>\r\n      </div>\r\n    </div>\r\n\r\n    <el-dialog title=\"工单信息\" :visible.sync=\"fromVisible\" width=\"40%\" :close-on-click-modal=\"false\" destroy-on-close>\r\n      <el-form label-width=\"100px\" style=\"padding-right: 50px\" :model=\"form\" :rules=\"rules\" ref=\"formRef\">\r\n        <el-form-item prop=\"repairTime\" label=\"割接时间\" >\r\n          <el-date-picker v-model=\"form.repairTime\" type=\"datetime\" placeholder=\"选择日期时间\" default-time=\"12:00:00\" format=\"yyyy-MM-dd HH:mm:ss\" value-format=\"yyyy-MM-dd HH:mm:ss\">\r\n          </el-date-picker>\r\n        </el-form-item>\r\n      </el-form>\r\n      <div slot=\"footer\" class=\"dialog-footer\">\r\n        <el-button @click=\"fromVisible = false\">取 消</el-button>\r\n        <el-button type=\"primary\" @click=\"save\">确 定</el-button>\r\n      </div>\r\n    </el-dialog>\r\n\r\n  </div>\r\n</template>\r\n\r\n\r\n<script>\r\nexport default {\r\n  name: \"UserOrders\",\r\n  data() {\r\n    return {\r\n      user: JSON.parse(sessionStorage.getItem('sys-user') || '{}'),\r\n\r\n      tableData: [],\r\n      pageNum: 1,\r\n      pageSize: 10,\r\n      total: 0,\r\n\r\n      orderSn: null,\r\n\r\n      fromVisible: false,\r\n      form: {},\r\n\r\n      rules: {\r\n        repairTime: [{required: true, message: '必填', trigger: 'blur'},],\r\n      },\r\n    }\r\n  },\r\n  created() {\r\n    this.load(1)\r\n  },\r\n  methods: {\r\n    load(pageNum) {\r\n      if (pageNum) this.pageNum = pageNum\r\n      this.$request.get('/orders/selectPage', {\r\n        params: {\r\n          pageNum: this.pageNum,\r\n          pageSize: this.pageSize,\r\n          orderSn: this.orderSn,\r\n          userId: this.user.id,\r\n        }\r\n      }).then(res => {\r\n        this.tableData = res.data?.list\r\n        this.total = res.data?.total\r\n      })\r\n    },\r\n    reset() {\r\n      this.title = null\r\n      this.load(1)\r\n    },\r\n    handleEdit(row) {\r\n      this.form = JSON.parse(JSON.stringify(row))\r\n      this.fromVisible = true\r\n    },\r\n    save() {\r\n      this.$refs.formRef.validate((valid) => {\r\n        if (valid) {\r\n          this.form.state = 2\r\n          this.$request({\r\n            url:  '/orders/update',\r\n            method: 'PUT',\r\n            data: this.form\r\n          }).then(res => {\r\n            if (res.code === '200') {\r\n              this.$message.success('保存成功')\r\n              this.load(1)\r\n              this.fromVisible = false\r\n            } else {\r\n              this.$message.error(res.msg)\r\n            }\r\n          })\r\n        }\r\n      })\r\n    },\r\n    handleCurrentChange(pageNum) {\r\n      this.load(pageNum)\r\n    },\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n\r\n</style>"],"mappings":"AAuEA;EACAA,IAAA;EACAC,KAAA;IACA;MACAC,IAAA,EAAAC,IAAA,CAAAC,KAAA,CAAAC,cAAA,CAAAC,OAAA;MAEAC,SAAA;MACAC,OAAA;MACAC,QAAA;MACAC,KAAA;MAEAC,OAAA;MAEAC,WAAA;MACAC,IAAA;MAEAC,KAAA;QACAC,UAAA;UAAAC,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA;MACA;IACA;EACA;EACAC,QAAA;IACA,KAAAC,IAAA;EACA;EACAC,OAAA;IACAD,KAAAZ,OAAA;MACA,IAAAA,OAAA,OAAAA,OAAA,GAAAA,OAAA;MACA,KAAAc,QAAA,CAAAC,GAAA;QACAC,MAAA;UACA