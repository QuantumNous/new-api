{"ast":null,"code":"export default {\n  name: \"CuserPerson\",\n  data() {\n    return {\n      user: JSON.parse(sessionStorage.getItem('sys-user') || '{}'),\n      rules: {\n        name: [{\n          required: true,\n          message: '请输入姓名',\n          trigger: 'blur'\n        }],\n        phone: [{\n          pattern: /^1[3-9]\\d{9}$/,\n          message: '手机号格式不正确',\n          trigger: 'blur'\n        }],\n        email: [{\n          type: 'email',\n          message: '邮箱格式不正确',\n          trigger: 'blur'\n        }]\n      }\n    };\n  },\n  created() {},\n  methods: {\n    update() {\n      this.$refs.formRef.validate(valid => {\n        if (valid) {\n          this.$request.put('/user/update', this.user).then(res => {\n            if (res.code === '200') {\n              this.$message.success('保存成功');\n              sessionStorage.setItem('sys-user', JSON.stringify(this.user));\n              this.$emit('update:user');\n            } else {\n              this.$message.error(res.msg);\n            }\n          });\n        }\n      });\n    },\n    handleAvatarSuccess(response, file, fileList) {\n      this.$set(this.user, 'avatar', response.data);\n    }\n  }\n};","map":{"version":3,"names":["name","data","user","JSON","parse","sessionStorage","getItem","rules","required","message","trigger","phone","pattern","email","type","created","methods","update","$refs","formRef","validate","valid","$request","put","then","res","code","$message","success","setItem","stringify","$emit","error","msg","handleAvatarSuccess","response","file","fileList","$set"],"sources":["src/views/manager/CuserPerson.vue"],"sourcesContent":["<template>\r\n  <div>\r\n    <el-card style=\"width: 50%;margin: 30px auto\">\r\n      <el-form :model=\"user\" label-width=\"100px\" style=\"padding-right: 50px\" :rules=\"rules\" ref=\"formRef\">\r\n        <div style=\"margin: 15px; text-align: center\">\r\n          <el-upload\r\n              class=\"avatar-uploader\"\r\n              :action=\"$baseUrl + '/files/upload'\"\r\n              :show-file-list=\"false\"\r\n              :on-success=\"handleAvatarSuccess\"\r\n          >\r\n            <img v-if=\"user.avatar\" :src=\"user.avatar\" class=\"avatar\"/>\r\n            <i v-else class=\"el-icon-plus avatar-uploader-icon\"></i>\r\n          </el-upload>\r\n        </div>\r\n        <el-form-item label=\"用户名\" prop=\"username\">\r\n          <el-input v-model=\"user.username\" placeholder=\"用户名\" disabled></el-input>\r\n        </el-form-item>\r\n        <el-form-item label=\"姓名\" prop=\"name\">\r\n          <el-input v-model=\"user.name\" placeholder=\"姓名\"></el-input>\r\n        </el-form-item>\r\n        <el-form-item label=\"电话\" prop=\"phone\">\r\n          <el-input v-model=\"user.phone\" placeholder=\"电话\"></el-input>\r\n        </el-form-item>\r\n        <el-form-item label=\"邮箱\" prop=\"email\">\r\n          <el-input v-model=\"user.email\" placeholder=\"邮箱\"></el-input>\r\n        </el-form-item>\r\n        <div style=\"text-align: center; margin-bottom: 20px\">\r\n          <el-button type=\"info\" plain @click=\"update\">保 存</el-button>\r\n        </div>\r\n      </el-form>\r\n    </el-card>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: \"CuserPerson\",\r\n  data() {\r\n    return {\r\n      user: JSON.parse(sessionStorage.getItem('sys-user') || '{}'),\r\n      rules: {\r\n        name: [{required: true, message: '请输入姓名', trigger: 'blur'},],\r\n        phone: [{pattern: /^1[3-9]\\d{9}$/, message: '手机号格式不正确', trigger: 'blur'}],\r\n        email: [{type: 'email', message: '邮箱格式不正确', trigger: 'blur'}],\r\n      },\r\n    }\r\n  },\r\n  created() {\r\n\r\n  },\r\n  methods: {\r\n    update() {\r\n      this.$refs.formRef.validate((valid) => {\r\n        if (valid) {\r\n          this.$request.put('/user/update', this.user).then(res => {\r\n            if (res.code === '200') {\r\n              this.$message.success('保存成功')\r\n              sessionStorage.setItem('sys-user', JSON.stringify(this.user))\r\n              this.$emit('update:user')\r\n            } else {\r\n              this.$message.error(res.msg)\r\n            }\r\n          })\r\n        }\r\n      })\r\n    },\r\n    handleAvatarSuccess(response, file, fileList) {\r\n      this.$set(this.user, 'avatar', response.data)\r\n    },\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n/deep/ .el-form-item__label {\r\n  font-weight: bold;\r\n}\r\n\r\n/deep/ .el-upload {\r\n  border-radius: 50%;\r\n}\r\n\r\n/deep/ .avatar-uploader .el-upload {\r\n  border: 1px dashed #d9d9d9;\r\n  cursor: pointer;\r\n  position: relative;\r\n  overflow: hidden;\r\n  border-radius: 50%;\r\n}\r\n\r\n/deep/ .avatar-uploader .el-upload:hover {\r\n  border-color: #409EFF;\r\n}\r\n\r\n.avatar-uploader-icon {\r\n  font-size: 28px;\r\n  color: #8c939d;\r\n  width: 120px;\r\n  height: 120px;\r\n  line-height: 120px;\r\n  text-align: center;\r\n  border-radius: 50%;\r\n}\r\n\r\n.avatar {\r\n  width: 120px;\r\n  height: 120px;\r\n  display: block;\r\n  border-radius: 50%;\r\n}\r\n</style>"],"mappings":"AAoCA;EACAA,IAAA;EACAC,KAAA;IACA;MACAC,IAAA,EAAAC,IAAA,CAAAC,KAAA,CAAAC,cAAA,CAAAC,OAAA;MACAC,KAAA;QACAP,IAAA;UAAAQ,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA;QACAC,KAAA;UAAAC,OAAA;UAAAH,OAAA;UAAAC,OAAA;QAAA;QACAG,KAAA;UAAAC,IAAA;UAAAL,OAAA;UAAAC,OAAA;QAAA;MACA;IACA;EACA;EACAK,QAAA,GAEA;EACAC,OAAA;IACAC,OAAA;MACA,KAAAC,KAAA,CAAAC,OAAA,CAAAC,QAAA,CAAAC,KAAA;QACA,IAAAA,KAAA;UACA,KAAAC,QAAA,CAAAC,GAAA,sBAAArB,IAAA,EAAAsB,IAAA,CAAAC,GAAA;YACA,IAAAA,GAAA,CAAAC,IAAA;cACA,KAAAC,QAAA,CAAAC,OAAA;cACAvB,cAAA,CAAAwB,OAAA,aAAA1B,IAAA,CAAA2B,SAAA,MAAA5B,IAAA;cACA,KAAA6B,KAAA;YACA;cACA,KAAAJ,QAAA,CAAAK,KAAA,CAAAP,GAAA,CAAAQ,GAAA;YACA;UACA;QACA;MACA;IACA;IACAC,oBAAAC,QAAA,EAAAC,IAAA,EAAAC,QAAA;MACA,KAAAC,IAAA,MAAApC,IAAA,YAAAiC,QAAA,CAAAlC,IAAA;IACA;EACA;AACA"},"metadata":{},"sourceType":"module","externalDependencies":[]}