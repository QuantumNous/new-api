{"ast":null,"code":"import * as echarts from 'echarts';\nexport default {\n  name: 'Home',\n  data() {\n    return {\n      user: JSON.parse(sessionStorage.getItem('sys-user') || '{}')\n    };\n  },\n  mounted() {\n    this.initChart();\n    this.loadChartData();\n  },\n  methods: {\n    initChart() {\n      this.chart = echarts.init(document.getElementById('chart'));\n    },\n    loadChartData() {\n      this.$request.get('/centrality/dailyCounts').then(res => {\n        const data = res;\n        const dates = data.map(item => item.date);\n        const totals = data.map(item => item.total);\n        const option = {\n          title: {\n            text: '最近一个月每天的总数量'\n          },\n          tooltip: {\n            trigger: 'axis'\n          },\n          xAxis: {\n            type: 'category',\n            data: dates\n          },\n          yAxis: {\n            type: 'value'\n          },\n          series: [{\n            data: totals,\n            type: 'line'\n          }]\n        };\n        this.chart.setOption(option);\n      });\n    }\n  }\n};","map":{"version":3,"names":["echarts","name","data","user","JSON","parse","sessionStorage","getItem","mounted","initChart","loadChartData","methods","chart","init","document","getElementById","$request","get","then","res","dates","map","item","date","totals","total","option","title","text","tooltip","trigger","xAxis","type","yAxis","series","setOption"],"sources":["src/views/manager/Home.vue"],"sourcesContent":["<template>\n  <div>\n    <div class=\"card\" style=\"padding: 15px\">\n      您好，{{ user?.name }}！欢迎使用本系统\n    </div>\n\n    <el-card style=\"margin-top: 10px\">\n      <div id=\"chart\" style=\"width: 100%; height: 400px;\"></div>\n    </el-card>\n    <div style=\" margin: 10px 0\">\n\n    </div>\n  </div>\n</template>\n\n<script>\nimport * as echarts from 'echarts';\n\nexport default {\n  name: 'Home',\n  data() {\n    return {\n      user: JSON.parse(sessionStorage.getItem('sys-user') || '{}'),\n    }\n  },\n  mounted() {\n    this.initChart();\n    this.loadChartData();\n  },\n  methods: {\n    initChart() {\n      this.chart = echarts.init(document.getElementById('chart'));\n    },\n    loadChartData() {\n      this.$request.get('/centrality/dailyCounts').then(res => {\n        const data = res;\n        const dates = data.map((item) => item.date);\n        const totals = data.map((item) => item.total);\n\n        const option = {\n          title: {\n            text: '最近一个月每天的总数量',\n          },\n          tooltip: {\n            trigger: 'axis',\n          },\n          xAxis: {\n            type: 'category',\n            data: dates,\n          },\n          yAxis: {\n            type: 'value',\n          },\n          series: [\n            {\n              data: totals,\n              type: 'line',\n            },\n          ],\n        };\n\n        this.chart.setOption(option);\n      })\n    },\n  },\n}\n</script>\n"],"mappings":"AAgBA,YAAAA,OAAA;AAEA;EACAC,IAAA;EACAC,KAAA;IACA;MACAC,IAAA,EAAAC,IAAA,CAAAC,KAAA,CAAAC,cAAA,CAAAC,OAAA;IACA;EACA;EACAC,QAAA;IACA,KAAAC,SAAA;IACA,KAAAC,aAAA;EACA;EACAC,OAAA;IACAF,UAAA;MACA,KAAAG,KAAA,GAAAZ,OAAA,CAAAa,IAAA,CAAAC,QAAA,CAAAC,cAAA;IACA;IACAL,cAAA;MACA,KAAAM,QAAA,CAAAC,GAAA,4BAAAC,IAAA,CAAAC,GAAA;QACA,MAAAjB,IAAA,GAAAiB,GAAA;QACA,MAAAC,KAAA,GAAAlB,IAAA,CAAAmB,GAAA,CAAAC,IAAA,IAAAA,IAAA,CAAAC,IAAA;QACA,MAAAC,MAAA,GAAAtB,IAAA,CAAAmB,GAAA,CAAAC,IAAA,IAAAA,IAAA,CAAAG,KAAA;QAEA,MAAAC,MAAA;UACAC,KAAA;YACAC,IAAA;UACA;UACAC,OAAA;YACAC,OAAA;UACA;UACAC,KAAA;YACAC,IAAA;YACA9B,IAAA,EAAAkB;UACA;UACAa,KAAA;YACAD,IAAA;UACA;UACAE,MAAA,GACA;YACAhC,IAAA,EAAAsB,MAAA;YACAQ,IAAA;UACA;QAEA;QAEA,KAAApB,KAAA,CAAAuB,SAAA,CAAAT,MAAA;MACA;IACA;EACA;AACA"},"metadata":{},"sourceType":"module","externalDependencies":[]}