{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nexport default {\n  name: \"Manager\",\n  data() {\n    return {\n      user: JSON.parse(sessionStorage.getItem('sys-user') || '{}')\n    };\n  },\n  created() {\n    if (!this.user.id) {\n      this.$router.push('/login');\n    }\n  },\n  methods: {\n    updateUser() {\n      this.user = JSON.parse(sessionStorage.getItem('sys-user') || '{}');\n    },\n    goToPerson() {\n      if (this.user.role === 'ADMIN') {\n        this.$router.push('/adminPerson');\n      }\n      if (this.user.role === 'USER') {\n        this.$router.push('/userPerson');\n      }\n      if (this.user.role === 'IAM') {\n        this.$router.push('/iamPerson');\n      }\n    },\n    logout() {\n      sessionStorage.removeItem('sys-user');\n      this.$router.push('/login');\n    }\n  }\n};","map":{"version":3,"names":["name","data","user","JSON","parse","sessionStorage","getItem","created","id","$router","push","methods","updateUser","goToPerson","role","logout","removeItem"],"sources":["src/views/Manager.vue"],"sourcesContent":["<template>\r\n  <div class=\"manager-container\">\r\n    <div class=\"manager-header\">\r\n      <div class=\"manager-header-left\">\r\n        <div class=\"title\" style=\"text-align: center\">分光器管理系统</div>\r\n      </div>\r\n\r\n      <div class=\"manager-header-center\">\r\n        <el-breadcrumb separator-class=\"el-icon-arrow-right\">\r\n          <el-breadcrumb-item :to=\"{ path: '/' }\">首页</el-breadcrumb-item>\r\n          <el-breadcrumb-item :to=\"{ path: $route.path }\">{{ $route.meta.name }}</el-breadcrumb-item>\r\n        </el-breadcrumb>\r\n      </div>\r\n\r\n      <div class=\"manager-header-right\">\r\n        <el-dropdown placement=\"bottom\">\r\n          <div class=\"avatar\">\r\n            <img :src=\"user.avatar || require('@/assets/imgs/defaultAvatar.png')\" />\r\n            <div>{{ user.name || user.username }}</div>\r\n          </div>\r\n          <el-dropdown-menu slot=\"dropdown\">\r\n            <el-dropdown-item @click.native=\"goToPerson\">个人信息</el-dropdown-item>\r\n            <el-dropdown-item @click.native=\"$router.push('/password')\">修改密码</el-dropdown-item>\r\n            <el-dropdown-item @click.native=\"logout\">退出登录</el-dropdown-item>\r\n          </el-dropdown-menu>\r\n        </el-dropdown>\r\n      </div>\r\n    </div>\r\n\r\n    <div class=\"manager-main\">\r\n      <div class=\"manager-main-left\">\r\n        <el-menu :default-openeds=\"['info', 'user']\" router style=\"border: none\" :default-active=\"$route.path\">\r\n          <el-menu-item index=\"/home\">\r\n            <i class=\"el-icon-s-home\"></i>\r\n            <span slot=\"title\">系统首页</span>\r\n          </el-menu-item>\r\n          <el-submenu index=\"info\">\r\n            <template slot=\"title\">\r\n              <i class=\"el-icon-menu\"></i><span>信息管理</span>\r\n            </template>\r\n            <el-menu-item index=\"/customer\" v-if=\"user.role === 'ADMIN'\">客户信息</el-menu-item>\r\n            <el-menu-item index=\"/equipment\" v-if=\"user.role === 'ADMIN'\">分光器信息</el-menu-item>\r\n            <el-menu-item index=\"/orders\" v-if=\"user.role === 'ADMIN'\">工单信息</el-menu-item>\r\n            <el-menu-item index=\"/centrality\" v-if=\"user.role === 'ADMIN'\">资源中心</el-menu-item>\r\n            <el-menu-item index=\"/userOrders\" v-if=\"user.role === 'USER'\">我的工单</el-menu-item>\r\n            <el-menu-item index=\"/iamOrders\" v-if=\"user.role === 'IAM'\">我的工单</el-menu-item>\r\n          </el-submenu>\r\n\r\n          <el-submenu index=\"user\" v-if=\"user.role === 'ADMIN'\">\r\n            <template slot=\"title\">\r\n              <i class=\"el-icon-menu\"></i><span>用户管理</span>\r\n            </template>\r\n            <el-menu-item index=\"/admin\">管理员</el-menu-item>\r\n            <el-menu-item index=\"/user\">客户经理</el-menu-item>\r\n            <el-menu-item index=\"/iam\">装维</el-menu-item>\r\n            <el-menu-item index=\"/iam\">资源中心用户</el-menu-item>\r\n          </el-submenu>\r\n        </el-menu>\r\n      </div>\r\n\r\n      <div class=\"manager-main-right\">\r\n        <router-view @update:user=\"updateUser\" />\r\n      </div>\r\n    </div>\r\n\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: \"Manager\",\r\n  data() {\r\n    return {\r\n      user: JSON.parse(sessionStorage.getItem('sys-user') || '{}'),\r\n    }\r\n  },\r\n  created() {\r\n    if (!this.user.id) {\r\n      this.$router.push('/login')\r\n    }\r\n  },\r\n  methods: {\r\n    updateUser() {\r\n      this.user = JSON.parse(sessionStorage.getItem('sys-user') || '{}')\r\n    },\r\n    goToPerson() {\r\n      if (this.user.role === 'ADMIN') {\r\n        this.$router.push('/adminPerson')\r\n      }\r\n      if (this.user.role === 'USER') {\r\n        this.$router.push('/userPerson')\r\n      }\r\n      if (this.user.role === 'IAM') {\r\n        this.$router.push('/iamPerson')\r\n      }\r\n    },\r\n    logout() {\r\n      sessionStorage.removeItem('sys-user')\r\n      this.$router.push('/login')\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n@import \"@/assets/css/manager.css\";\r\n</style>"],"mappings":";AAqEA;EACAA,IAAA;EACAC,KAAA;IACA;MACAC,IAAA,EAAAC,IAAA,CAAAC,KAAA,CAAAC,cAAA,CAAAC,OAAA;IACA;EACA;EACAC,QAAA;IACA,UAAAL,IAAA,CAAAM,EAAA;MACA,KAAAC,OAAA,CAAAC,IAAA;IACA;EACA;EACAC,OAAA;IACAC,WAAA;MACA,KAAAV,IAAA,GAAAC,IAAA,CAAAC,KAAA,CAAAC,cAAA,CAAAC,OAAA;IACA;IACAO,WAAA;MACA,SAAAX,IAAA,CAAAY,IAAA;QACA,KAAAL,OAAA,CAAAC,IAAA;MACA;MACA,SAAAR,IAAA,CAAAY,IAAA;QACA,KAAAL,OAAA,CAAAC,IAAA;MACA;MACA,SAAAR,IAAA,CAAAY,IAAA;QACA,KAAAL,OAAA,CAAAC,IAAA;MACA;IACA;IACAK,OAAA;MACAV,cAAA,CAAAW,UAAA;MACA,KAAAP,OAAA,CAAAC,IAAA;IACA;EACA;AACA"},"metadata":{},"sourceType":"module","externalDependencies":[]}