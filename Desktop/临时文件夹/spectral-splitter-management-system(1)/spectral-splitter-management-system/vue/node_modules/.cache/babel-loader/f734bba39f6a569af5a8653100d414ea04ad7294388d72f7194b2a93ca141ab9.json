{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nexport default {\n  name: \"Login\",\n  data() {\n    return {\n      form: {\n        role: 'ADMIN'\n      },\n      captchaCode: '',\n      captchaImage: '',\n      rules: {\n        username: [{\n          required: true,\n          message: '请输入账号',\n          trigger: 'blur'\n        }],\n        password: [{\n          required: true,\n          message: '请输入密码',\n          trigger: 'blur'\n        }]\n      }\n    };\n  },\n  created() {\n    this.refreshCaptcha();\n  },\n  methods: {\n    login() {\n      this.$refs['formRef'].validate(valid => {\n        if (valid) {\n          if (this.form.captchaCode !== this.captchaCode) {\n            this.$message.warning(\"验证码错误\");\n            return;\n          }\n          this.$request.post('/login', this.form).then(res => {\n            if (res.code === '200') {\n              this.$message.success('登录成功');\n              localStorage.setItem(\"xm-user\", JSON.stringify(res.data));\n              if (res.data.role === 'USER') this.$router.push('/front/home');else this.$router.push('/');\n            } else {\n              this.$message.error(res.msg);\n            }\n          });\n        }\n      });\n    },\n    refreshCaptcha() {\n      this.$request.get('/captcha').then(res => {\n        this.captchaCode = res.code;\n        this.captchaImage = res.image;\n      });\n      // document.getElementById(\"captchaCode\").src = this.$baseUrl + \"/captcha?time=\" + new Date().getTime();\n    }\n  }\n};","map":{"version":3,"names":["name","data","form","role","captchaCode","captchaImage","rules","username","required","message","trigger","password","created","refreshCaptcha","methods","login","$refs","validate","valid","$message","warning","$request","post","then","res","code","success","localStorage","setItem","JSON","stringify","$router","push","error","msg","get","image"],"sources":["src/views/Login.vue"],"sourcesContent":["<template>\r\n  <div class=\"container\">\r\n    <div style=\"width: 400px; padding: 30px; background-color: rgba(255, 255, 255, 0.8); border-radius: 15px;\">\r\n      <div style=\"text-align: center; font-size: 24px; margin-bottom: 20px; color: #333;font-weight: bold\">管理系统</div>\r\n      <el-form :model=\"form\" :rules=\"rules\" ref=\"formRef\">\r\n        <el-form-item prop=\"username\">\r\n          <el-input prefix-icon=\"el-icon-user\" size=\"medium\" placeholder=\"请输入账号\" v-model=\"form.username\"></el-input>\r\n        </el-form-item>\r\n        <el-form-item prop=\"password\">\r\n          <el-input prefix-icon=\"el-icon-lock\" size=\"medium\" placeholder=\"请输入密码\" show-password\r\n                    v-model=\"form.password\"></el-input>\r\n        </el-form-item>\r\n        <el-form-item prop=\"captchaCode\">\r\n          <el-input size=\"medium\" placeholder=\"请输入验证码\" v-model=\"form.captchaCode\"></el-input>\r\n          <img style=\"float: right\" :src=\"captchaImage\" @click=\"refreshCaptcha()\"/>\r\n        </el-form-item>\r\n        <el-form-item prop=\"role\">\r\n          <el-radio-group v-model=\"form.role\">\r\n            <el-radio label=\"ADMIN\">管理员</el-radio>\r\n            <el-radio label=\"USER\">用户</el-radio>\r\n          </el-radio-group>\r\n          <img style=\"float: right\" :src=\"captchaImage\" @click=\"refreshCaptcha()\"/>\r\n        </el-form-item>\r\n        <el-form-item>\r\n          <el-button type=\"info\" size=\"medium\" style=\"width: 100%;\" @click=\"login\">登 录</el-button>\r\n        </el-form-item>\r\n        <div style=\"display: flex; align-items: center\">\r\n          <div style=\"flex: 1\"></div>\r\n          <div style=\"flex: 1; text-align: right\">\r\n            还没有账号？请 <span style=\"color: #2a60c9;cursor: pointer\" @click=\"$router.push('/register')\">注册</span>\r\n          </div>\r\n        </div>\r\n      </el-form>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: \"Login\",\r\n  data() {\r\n    return {\r\n      form: {role: 'ADMIN'},\r\n      captchaCode: '',\r\n      captchaImage: '',\r\n      rules: {\r\n        username: [{required: true, message: '请输入账号', trigger: 'blur'},],\r\n        password: [{required: true, message: '请输入密码', trigger: 'blur'},],\r\n      }\r\n    }\r\n  },\r\n  created() {\r\n    this.refreshCaptcha()\r\n  },\r\n  methods: {\r\n    login() {\r\n      this.$refs['formRef'].validate((valid) => {\r\n        if (valid) {\r\n          if (this.form.captchaCode !== this.captchaCode) {\r\n            this.$message.warning(\"验证码错误\");\r\n            return\r\n          }\r\n          this.$request.post('/login', this.form).then(res => {\r\n            if (res.code === '200') {\r\n              this.$message.success('登录成功')\r\n              localStorage.setItem(\"xm-user\", JSON.stringify(res.data))\r\n              if (res.data.role === 'USER')\r\n                this.$router.push('/front/home')\r\n              else\r\n                this.$router.push('/')\r\n            } else {\r\n              this.$message.error(res.msg)\r\n            }\r\n          })\r\n        }\r\n      })\r\n    },\r\n    refreshCaptcha() {\r\n      this.$request.get('/captcha').then(res => {\r\n        this.captchaCode = res.code;\r\n        this.captchaImage = res.image;\r\n      })\r\n      // document.getElementById(\"captchaCode\").src = this.$baseUrl + \"/captcha?time=\" + new Date().getTime();\r\n    },\r\n\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n.container {\r\n  height: 100vh;\r\n  overflow: hidden;\r\n  background-image: url(\"@/assets/imgs/bg.jpg\");\r\n  background-size: 100%;\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  color: #666;\r\n}\r\n\r\na {\r\n  color: #2a60c9;\r\n}\r\n</style>"],"mappings":";AAsCA;EACAA,IAAA;EACAC,KAAA;IACA;MACAC,IAAA;QAAAC,IAAA;MAAA;MACAC,WAAA;MACAC,YAAA;MACAC,KAAA;QACAC,QAAA;UAAAC,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA;QACAC,QAAA;UAAAH,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA;MACA;IAC