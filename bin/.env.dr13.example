# DR-13 test token environment variables.
# Copy this file to bin/.env.dr13 and fill in your values:
#
#   cp bin/.env.dr13.example bin/.env.dr13
#
# bin/.env.dr13 is gitignored — your tokens will never be committed.

BASE_URL=http://localhost:3000

RPM_KEY=sk-REPLACE_ME
TPM_KEY=sk-REPLACE_ME
MONTHLY_KEY=sk-REPLACE_ME
ROOT_KEY=sk-REPLACE_ME
RPM1_KEY=sk-REPLACE_ME
MONTHLY1_KEY=sk-REPLACE_ME
COMBO_KEY=sk-REPLACE_ME

# Token DB IDs — find these in the admin UI or via GET /api/token
COMBO_TOKEN_ID=0
MONTHLY1_TOKEN_ID=0
MONTHLY_TOKEN_ID=0
