#!/usr/bin/env bash
# Copy this file to bin/run-dr13-human-test.local.sh and fill in your values.
# *.local.sh is gitignored — your tokens will NEVER be committed.
#
#   cp bin/run-dr13-human-test.local.sh.example bin/run-dr13-human-test.local.sh
#   # edit the file, fill in your keys
#   bash bin/run-dr13-human-test.local.sh

export RPM_KEY="sk-REPLACE_ME"
export TPM_KEY="sk-REPLACE_ME"
export MONTHLY_KEY="sk-REPLACE_ME"
export ROOT_KEY="sk-REPLACE_ME"
export RPM1_KEY="sk-REPLACE_ME"
export MONTHLY1_KEY="sk-REPLACE_ME"
export COMBO_KEY="sk-REPLACE_ME"
export COMBO_TOKEN_ID=0        # replace with the token DB id for COMBO_KEY
export MONTHLY1_TOKEN_ID=0     # replace with the token DB id for MONTHLY1_KEY
export MONTHLY_TOKEN_ID=0      # replace with the token DB id for MONTHLY_KEY
export BASE_URL="http://localhost:3000"

bash "$(dirname "$0")/run-dr13-human-test.sh"
