# New API 环境变量配置
# 复制为 .env 并上传到服务器 /opt/new-api/.env

# ====== 数据库 ======
SQL_DSN=new_api:password@tcp(127.0.0.1:3306)/new_api

# ====== Redis ======
REDIS_CONN_STRING=redis://default:password@127.0.0.1:6379

# ====== 密钥（所有节点必须一致） ======
# 生成方式: openssl rand -hex 32
SESSION_SECRET=
CRYPTO_SECRET=

# ====== 节点配置 ======
# 主节点留空，从节点设为 slave
NODE_TYPE=
SYNC_FREQUENCY=60

# ====== 批量更新 ======
BATCH_UPDATE_ENABLED=true
BATCH_UPDATE_INTERVAL=5

# ====== 时区 ======
TZ=Asia/Shanghai
