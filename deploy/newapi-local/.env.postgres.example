NEWAPI_POSTGRES_DB=newapi
NEWAPI_POSTGRES_USER=newapi
NEWAPI_POSTGRES_PASSWORD=change_this_postgres_password
OPTION_CRYPT_KEY=change_this_to_a_64_char_hex_key

# Skill Hub Zip OSS upload. Zip bucket can stay private; downloads use signed OSS redirects.
# SKILL_HUB_OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
# SKILL_HUB_OSS_BUCKET=your-private-bucket
# SKILL_HUB_OSS_ACCESS_KEY_ID=your-access-key-id
# SKILL_HUB_OSS_ACCESS_KEY_SECRET=your-access-key-secret
# SKILL_HUB_OSS_PREFIX=skill-hub/skills
# SKILL_HUB_OSS_SIGNED_URL_EXPIRES_SECONDS=600

# Skill Hub icon OSS upload. Icons must be uploaded and served from a stable public HTTPS URL.
# SKILL_HUB_OSS_ICON_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
# SKILL_HUB_OSS_ICON_BUCKET=z-up-api-public
# SKILL_HUB_OSS_ICON_ACCESS_KEY_ID=your-icon-access-key-id
# SKILL_HUB_OSS_ICON_ACCESS_KEY_SECRET=your-icon-access-key-secret
# SKILL_HUB_OSS_ICON_PREFIX=skill-hub/icons
# SKILL_HUB_OSS_ICON_PUBLIC_BASE_URL=https://z-up-api-public.oss-cn-hangzhou.aliyuncs.com
