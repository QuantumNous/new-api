# 复制为 .env 后使用，密钥请用 `openssl rand -hex 32` 生成。
NEW_API_IMAGE=calciumion/new-api:latest
NEW_API_BIND_HOST=127.0.0.1
NEW_API_PORT=3000
TZ=Asia/Shanghai

POSTGRES_USER=newapi
POSTGRES_PASSWORD=change_me
POSTGRES_DB=newapi

REDIS_PASSWORD=change_me

SESSION_SECRET=change_me
CRYPTO_SECRET=change_me

ERROR_LOG_ENABLED=true
BATCH_UPDATE_ENABLED=true
NODE_NAME=new-api-node-1
STREAMING_TIMEOUT=300
MAX_REQUEST_BODY_MB=128
STREAM_SCANNER_MAX_BUFFER_MB=128
