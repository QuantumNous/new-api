              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "headers": {},
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SkillHubListApiResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "SessionAuth": [],
