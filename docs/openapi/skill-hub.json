  "components": {
    "schemas": {
      "ApiResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "message": {
            "type": "string"
          },
          "data": {}
        }
      },
      "SkillHubCompatibility": {
        "type": "object",
        "properties": {
          "connectorMinVersion": {
            "type": "string",
            "description": "最低连接器版本"
          },
          "platforms": {
            "type": "array",
            "description": "支持的平台",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "SkillHubManifest": {
        "type": "object",
        "properties": {
          "entry": {
            "type": "string",
            "description": "技能入口文件，默认 SKILL.md"
          },
          "permissions": {
            "type": "array",
            "description": "manifest 中声明的权限",
            "items": {
              "type": "string"
            }
          },
          "tools": {
            "type": "array",
            "description": "manifest 中声明的工具",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "SkillHubSource": {
        "type": "object",
        "required": [
          "type",
          "url"
        ],
        "properties": {
          "type": {
            "type": "string",
            "description": "技能来源类型，目前仅支持 zip",
            "enum": [
              "zip"
            ]
          },
          "url": {
            "type": "string",
            "description": "技能包下载地址",
            "format": "uri"
          },
          "ref": {
            "type": "string",
            "description": "OSS 对象键；公开接口不会返回该字段"
          },
          "checksum": {
            "type": "string",
            "description": "技能包校验和，例如 sha256:<hex>"
          }
        }
      },
      "SkillHubSkill": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "技能 ID，只允许字母、数字、点、下划线和短横线，最长 128"
          },
          "name": {
            "type": "string",
            "description": "技能名称"
          },
          "description": {
            "type": "string",
            "description": "技能描述"
          },
          "version": {
            "type": "string",
            "description": "技能版本"
          },
          "author": {
            "type": "string",
            "description": "作者"
          },
          "icon": {
            "type": "string",
            "description": "图标 URL",
            "format": "uri"
          },
          "tags": {
            "type": "array",
            "description": "标签",
            "items": {
              "type": "string"
            }
          },
          "verified": {
            "type": "boolean",
            "description": "是否认证"
          },
          "recommended": {
            "type": "boolean",
            "description": "是否推荐"
          },
          "published": {
            "type": "boolean",
            "description": "是否已发布；公开接口不返回有效值"
          },
          "status": {
            "type": "integer",
            "description": "发布状态：0 草稿，1 已发布；公开接口不返回有效值",
            "enum": [
              0,
              1
            ]
          },
          "sort": {
            "type": "integer",
            "description": "排序权重，越大越靠前；公开接口不返回有效值"
          },
          "updatedAt": {
            "type": "string",
            "description": "更新时间",
            "format": "date-time"
          },
          "compatibility": {
            "$ref": "#/components/schemas/SkillHubCompatibility"
          },
          "permissions": {
            "type": "array",
            "description": "技能权限",
            "items": {
              "type": "string"
            }
          },
          "manifest": {
            "$ref": "#/components/schemas/SkillHubManifest"
          },
          "source": {
            "$ref": "#/components/schemas/SkillHubSource"
          },
          "changelog": {
            "type": "string",
            "description": "更新日志"
          }
        }
      },
      "SkillHubListData": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SkillHubSkill"
            }
          },
          "total": {
            "type": "integer",
            "format": "int64",
            "description": "总数"
          }
        }
      },
      "SkillHubSkillRequest": {
        "type": "object",
        "required": [
          "id",
          "name",
          "version",
          "source"
        ],
        "properties": {
          "id": {
            "type": "string",
            "description": "技能 ID，只允许字母、数字、点、下划线和短横线，最长 128"
          },
          "name": {
            "type": "string",
            "description": "技能名称"
          },
          "description": {
            "type": "string",
            "description": "技能描述"
          },
          "version": {
            "type": "string",
            "description": "技能版本"
          },
          "author": {
            "type": "string",
            "description": "作者"
          },
          "icon": {
            "type": "string",
            "description": "图标 URL",
            "format": "uri"
          },
          "tags": {
            "type": "array",
            "description": "标签",
            "items": {
              "type": "string"
            }
          },
          "verified": {
            "type": "boolean",
            "description": "是否认证"
          },
          "recommended": {
            "type": "boolean",
            "description": "是否推荐"
          },
          "published": {
            "type": "boolean",
            "description": "是否发布；未传 status 时使用该字段决定状态"
          },
          "status": {
            "type": "integer",
            "description": "发布状态：0 草稿，1 已发布；优先级高于 published",
            "enum": [
              0,
              1
            ]
          },
          "sort": {
            "type": "integer",
            "description": "排序权重，越大越靠前"
          },
          "compatibility": {
            "$ref": "#/components/schemas/SkillHubCompatibility"
          },
          "permissions": {
            "type": "array",
            "description": "技能权限",
            "items": {
              "type": "string"
            }
          },
          "manifest": {
            "$ref": "#/components/schemas/SkillHubManifest"
          },
          "source": {
            "$ref": "#/components/schemas/SkillHubSource"
          },
          "changelog": {
            "type": "string",
            "description": "更新日志"
          }
        }
      },
      "SkillHubUploadResult": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string",
            "description": "可访问 URL；zip 上传时返回技能下载接口地址，图标上传时返回图标公网地址",
            "format": "uri"
          },
          "object": {
            "type": "string",
            "description": "OSS 对象键"
          },
          "size": {
            "type": "integer",
            "format": "int64",
            "description": "文件大小，单位字节"
          },
          "checksum": {
            "type": "string",
            "description": "文件校验和，例如 sha256:<hex>"
          }
        }
      },
      "SkillHubListApiResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "message": {
            "type": "string"
          },
          "data": {
            "$ref": "#/components/schemas/SkillHubListData"
          }
        }
      },
      "SkillHubSkillApiResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "message": {
            "type": "string"
          },
          "data": {
            "$ref": "#/components/schemas/SkillHubSkill"
          }
        }
      },
      "SkillHubUploadApiResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "message": {
            "type": "string"
          },
          "data": {
            "$ref": "#/components/schemas/SkillHubUploadResult"
          }
        }
      },
      "SkillHubEmptyApiResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "message": {
            "type": "string"
          },
          "data": {
            "nullable": true
          }
        }
      }
    },
    "responses": {},
    "securitySchemes": {
      "SessionAuth": {
        "type": "apiKey",
        "in": "cookie",
        "name": "session",
        "description": "Session 认证，通过登录接口获取"
      },
      "AccessToken": {
        "type": "apiKey",
        "in": "header",
