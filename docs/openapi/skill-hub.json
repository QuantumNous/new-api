      "post": {
        "summary": "管理员创建技能",
        "deprecated": false,
        "description": "👨‍💼 需要管理员权限（Admin）",
        "tags": [
          "技能广场管理"
        ],
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SkillHubSkillRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "成功",
            "headers": {},
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SkillHubSkillApiResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "SessionAuth": [],
            "NewApiUser": []
          },
          {
            "AccessToken": [],
            "NewApiUser": []
          }
        ]
      }
    },
