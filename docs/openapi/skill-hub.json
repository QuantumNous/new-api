{
  "openapi": "3.0.1",
  "info": {
    "title": "技能广场接口",
    "description": "Skill Hub 技能广场公开浏览与管理员维护接口。",
    "version": "1.0.0"
  },
  "tags": [
    {
      "name": "技能广场",
      "description": "公开浏览与下载技能"
    },
    {
      "name": "技能广场管理",
      "description": "管理员维护技能、上传资源与发布状态"
    }
  ],
  "paths": {
    "/api/skill-hub/skills": {
      "get": {
        "summary": "获取技能广场技能列表",
        "deprecated": false,
        "description": "🔓 无需鉴权；仅返回已发布技能",
        "tags": [
          "技能广场"
        ],
        "parameters": [
          {
            "name": "keyword",
            "in": "query",
            "description": "搜索关键字，匹配技能 ID、名称、描述或标签",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "p",
            "in": "query",
            "description": "页码",
            "required": false,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "page_size",
            "in": "query",
            "description": "每页数量",
            "required": false,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "headers": {},
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SkillHubListApiResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/skill-hub/skills/{id}": {
      "get": {
        "summary": "获取技能广场技能详情",
        "deprecated": false,
        "description": "🔓 无需鉴权；仅可获取已发布技能",
        "tags": [
          "技能广场"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "技能 ID",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "headers": {},
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SkillHubSkillApiResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/skill-hub/skills/{id}/download": {
      "get": {
        "summary": "下载技能包",
        "deprecated": false,
        "description": "🔓 无需鉴权；成功时 302 跳转到技能包源地址或签名下载地址",
        "tags": [
          "技能广场"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "技能 ID",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "失败时返回统一 JSON 错误结构",
            "headers": {},
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse"
                }
              }
            }
          },
          "302": {
            "description": "跳转到技能包下载地址",
            "headers": {
              "Location": {
                "description": "技能包下载地址",
                "schema": {
                  "type": "string",
                  "format": "uri"
                }
              }
            }
          }
        }
      }
    },
    "/api/admin/skill-hub/upload": {
      "post": {
        "summary": "上传技能包",
        "deprecated": false,
        "description": "👨‍💼 需要管理员权限（Admin）；仅支持 zip 文件，最大 50MB",
        "tags": [
          "技能广场管理"
        ],
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": [
                  "file",
                  "skill_id"
                ],
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary",
                    "description": "zip 技能包文件"
                  },
                  "skill_id": {
                    "type": "string",
                    "description": "技能 ID"
                  },
                  "version": {
                    "type": "string",
                    "description": "技能版本"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "成功",
            "headers": {},
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SkillHubUploadApiResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "SessionAuth": [],
            "NewApiUser": []
          },
          {
            "AccessToken": [],
            "NewApiUser": []
          }
        ]
      }
    },
    "/api/admin/skill-hub/upload-icon": {
      "post": {
        "summary": "上传技能图标",
        "deprecated": false,
        "description": "👨‍💼 需要管理员权限（Admin）；支持 png、jpg、jpeg、webp，最大 1MB",
        "tags": [
          "技能广场管理"
        ],
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": [
                  "file",
                  "skill_id"
                ],
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary",
                    "description": "技能图标文件"
                  },
                  "skill_id": {
                    "type": "string",
                    "description": "技能 ID"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "成功",
            "headers": {},
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SkillHubUploadApiResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "SessionAuth": [],
            "NewApiUser": []
          },
          {
            "AccessToken": [],
            "NewApiUser": []
          }
        ]
      }
    },
