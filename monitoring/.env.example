# New API base URL (for Docker: host.docker.internal, for bare metal: localhost)
NEW_API_BASE=http://host.docker.internal:3002

# Feishu webhook URL (get from Feishu bot settings)
FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxxxx

# Admin credentials for log stats + user metrics scraping
NEW_API_ADMIN_USER=test
NEW_API_ADMIN_PASS=10086111

# User/Group monitoring (comma-separated, empty=auto-detect from admin API)
NEW_API_USER_LIST=
NEW_API_GROUP_LIST=internal,personal

# Scrape interval in seconds
SCRAPE_INTERVAL=30

# Report interval in minutes
REPORT_INTERVAL=60
