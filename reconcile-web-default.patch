@@ -0,0 +1,139 @@
+import { useState } from 'react'
+import { useQuery } from '@tanstack/react-query'
+import { useTranslation } from 'react-i18next'
+import { toast } from 'sonner'
+import {
+  Select,
+  SelectContent,
+  SelectItem,
+  SelectTrigger,
+  SelectValue,
+} from '@/components/ui/select'
+import { Label } from '@/components/ui/label'
+import { cn } from '@/lib/utils'
+import { queryReconcileSummary } from '../api'
+import { api } from '@/lib/api'
+
+type Channel = { id: number; name: string }
+
+export function SummaryCards() {
+  const { t } = useTranslation()
+  const [channelId, setChannelId] = useState<number>(0)
+
+  // Last 30 days — fixed at mount time. Date.now() in render body would be an
+  // impure call under React 19 strict mode and shifts the window every render.
+  const [{ from, to }] = useState(() => {
+    const now = Math.floor(Date.now() / 1000)
+    return { from: now - 30 * 86400, to: now }
+  })
+
+  const { data: channelsData } = useQuery({
+    queryKey: ['channels-for-reconcile'],
+    queryFn: async () => {
+      const res = await api.get('/api/channel?p=1&page_size=200&select_all=true')
+      return (res.data?.data as Channel[]) ?? []
+    },
+    staleTime: 60 * 1000,
+  })
+  const channels = channelsData ?? []
+
+  // t() is only used for the toast fallback inside queryFn; not a queryKey dep.
+  // eslint-disable-next-line @tanstack/query/exhaustive-deps
+  const { data, isLoading } = useQuery({
+    queryKey: ['reconcile-summary', channelId, from, to],
+    queryFn: async () => {
+      if (!channelId) return []
+      const res = await queryReconcileSummary({ channel_id: channelId, from, to })
+      if (!res.success) {
+        toast.error(res.message || t('Load failed'))
+        return []
+      }
+      return res.data ?? []
+    },
+    enabled: channelId > 0,
+  })
+
+  const rows = data ?? []
+  const totalOurs = rows.reduce((s, r) => s + r.ours_amount, 0)
+  const totalSupplier = rows.reduce((s, r) => s + r.supplier_amount, 0)
+  const totalDiff = totalSupplier - totalOurs
+
+  return (
+    <div className='space-y-4'>
+      <div className='flex items-center gap-4'>
+        <div className='flex flex-col gap-1'>
+          <Label className='text-xs'>{t('Channel')}</Label>
+          <Select
+            value={channelId ? String(channelId) : ''}
+            onValueChange={(v) => setChannelId(Number(v))}
+          >
+            <SelectTrigger className='h-8 w-[180px] text-xs'>
+              <SelectValue placeholder={t('Please select a channel')} />
+            </SelectTrigger>
+            <SelectContent>
+              {channels.map((c) => (
+                <SelectItem key={c.id} value={String(c.id)}>
+                  {c.name}
+                </SelectItem>
+              ))}
+            </SelectContent>
+          </Select>
+        </div>
+        <p className='text-xs text-muted-foreground pt-4'>{t('Last 30 days')}</p>
+      </div>
+
+      {!channelId ? (
+        <p className='text-sm text-muted-foreground'>{t('Please select a channel')}</p>
+      ) : isLoading ? (
+        <p className='text-sm text-muted-foreground'>{t('Loading...')}</p>
+      ) : rows.length === 0 ? (
+        <p className='text-sm text-muted-foreground'>{t('No data')}</p>
+      ) : (
+        <>
+          {/* Totals row */}
+          <div className='grid grid-cols-3 gap-4'>
+            {[
+              { label: t('Our Amount'), value: `¥${totalOurs.toFixed(4)}`, color: '' },
+              { label: t('Supplier Amount'), value: `¥${totalSupplier.toFixed(4)}`, color: '' },
+              {
+                label: t('Diff'),
+                value: `${totalDiff >= 0 ? '+' : ''}¥${totalDiff.toFixed(4)}`,
+                color: Math.abs(totalDiff) < 0.01 ? 'text-green-600' : 'text-red-600',
+              },
+            ].map((item) => (
+              <div key={item.label} className='rounded-lg border p-4 space-y-1'>
+                <p className='text-xs text-muted-foreground'>{item.label}</p>
+                <p className={cn('text-lg font-semibold font-mono', item.color)}>
+                  {item.value}
+                </p>
+              </div>
+            ))}
+          </div>
+
+          {/* Per-model cards */}
+          <div className='grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3'>
+            {rows.map((row) => {
+              const diffPct = row.supplier_amount
+                ? ((row.diff / row.supplier_amount) * 100).toFixed(2)
+                : '0.00'
+              return (
+                <div key={row.model_name} className='rounded-lg border p-4 space-y-2'>
+                  <p className='truncate font-mono text-xs font-medium' title={row.model_name}>
+                    {row.model_name}
+                  </p>
+                  <div className='flex justify-between text-xs text-muted-foreground'>
+                    <span>{t('Ours')}: ¥{row.ours_amount.toFixed(4)}</span>
+                    <span>{t('Supplier')}: ¥{row.supplier_amount.toFixed(4)}</span>
+                  </div>
+                  <div className={cn('text-xs font-mono', Math.abs(row.diff) < 0.001 ? 'text-green-600' : 'text-red-600')}>
+                    {t('Diff')}: {row.diff >= 0 ? '+' : ''}¥{row.diff.toFixed(4)} ({diffPct}%)
+                  </div>
+                </div>
+              )
+            })}
+          </div>
+        </>
+      )}
+    </div>
+  )
+}
