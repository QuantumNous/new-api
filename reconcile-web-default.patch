@@ -0,0 +1,188 @@
+import { useState } from 'react'
+import { useQuery } from '@tanstack/react-query'
+import { useTranslation } from 'react-i18next'
+import { toast } from 'sonner'
+import { Button } from '@/components/ui/button'
+import { Input } from '@/components/ui/input'
+import { Switch } from '@/components/ui/switch'
+import { Label } from '@/components/ui/label'
+import {
+  Select,
+  SelectContent,
+  SelectItem,
+  SelectTrigger,
+  SelectValue,
+} from '@/components/ui/select'
+import { triggerReaggregate, getExportUrl } from '../api'
+import { api } from '@/lib/api'
+
+type Channel = { id: number; name: string }
+
+type DiffFilter = {
+  channelId: number
+  from: number
+  to: number
+  modelName: string
+  onlyDiff: boolean
+}
+
+type Props = {
+  filter: DiffFilter
+  onFilterChange: (f: DiffFilter) => void
+}
+
+function toDateInputValue(unix: number) {
+  return new Date(unix * 1000).toISOString().slice(0, 10)
+}
+
+function fromDateInputValue(s: string, endOfDay = false): number {
+  const d = new Date(s)
+  if (endOfDay) d.setHours(23, 59, 59)
+  return Math.floor(d.getTime() / 1000)
+}
+
+function currentMonth(): string {
+  const now = new Date()
+  return `${now.getFullYear()}-${String(now.getMonth() + 1).padStart(2, '0')}`
+}
+
+export function DiffToolbar({ filter, onFilterChange }: Props) {
+  const { t } = useTranslation()
+  const [isReagg, setIsReagg] = useState(false)
+
+  const { data: channelsData } = useQuery({
+    queryKey: ['channels-for-reconcile'],
+    queryFn: async () => {
+      const res = await api.get('/api/channel?p=1&page_size=200&select_all=true')
+      return (res.data?.data as Channel[]) ?? []
+    },
+    staleTime: 60 * 1000,
+  })
+  const channels = channelsData ?? []
+
+  const handleReaggregate = async () => {
+    if (!filter.channelId) {
+      toast.error(t('Please select a channel'))
+      return
+    }
+    setIsReagg(true)
+    try {
+      const res = await triggerReaggregate({
+        channel_id: filter.channelId,
+        from: filter.from,
+        to: filter.to,
+      })
+      if (!res.success) throw new Error(res.message)
+      const processed = res.data?.processed_buckets ?? 0
+      const failed = res.data?.failed_buckets ?? 0
+      if (failed > 0) {
+        toast.warning(
+          t('Re-aggregation done, processed {{n}} hour buckets, {{f}} failed (see backend logs)', {
+            n: processed,
+            f: failed,
+          })
+        )
+      } else {
+        toast.success(t('Re-aggregation done, processed {{n}} hour buckets', { n: processed }))
+      }
+    } catch (e) {
+      toast.error(e instanceof Error ? e.message : t('Re-aggregate failed'))
+    } finally {
+      setIsReagg(false)
+    }
+  }
+
+  const handleExport = () => {
+    if (!filter.channelId) {
+      toast.error(t('Please select a channel'))
+      return
+    }
+    const url = getExportUrl({
+      channel_id: filter.channelId,
+      month: currentMonth(),
+      format: 'xlsx',
+      only_diff: false,
+    })
+    window.open(url, '_blank')
+  }
+
+  return (
+    <div className='flex flex-wrap items-end gap-3'>
+      {/* Channel */}
+      <div className='flex flex-col gap-1'>
+        <Label className='text-xs'>{t('Channel')}</Label>
+        <Select
+          value={filter.channelId ? String(filter.channelId) : ''}
+          onValueChange={(v) => onFilterChange({ ...filter, channelId: Number(v) })}
+        >
+          <SelectTrigger className='h-8 w-[180px] text-xs'>
+            <SelectValue placeholder={t('Please select a channel')} />
+          </SelectTrigger>
+          <SelectContent>
+            {channels.map((c) => (
+              <SelectItem key={c.id} value={String(c.id)}>
+                {c.name}
+              </SelectItem>
+            ))}
+          </SelectContent>
+        </Select>
+      </div>
+
+      {/* Date range */}
+      <div className='flex flex-col gap-1'>
+        <Label className='text-xs'>{t('Start Time')}</Label>
+        <Input
+          type='date'
+          className='h-8 w-[140px] text-xs'
+          value={toDateInputValue(filter.from)}
+          onChange={(e) =>
+            onFilterChange({ ...filter, from: fromDateInputValue(e.target.value, false) })
+          }
+        />
+      </div>
+      <div className='flex flex-col gap-1'>
+        <Label className='text-xs'>{t('End Time')}</Label>
+        <Input
+          type='date'
+          className='h-8 w-[140px] text-xs'
+          value={toDateInputValue(filter.to)}
+          onChange={(e) =>
+            onFilterChange({ ...filter, to: fromDateInputValue(e.target.value, true) })
+          }
+        />
+      </div>
+
+      {/* Model filter */}
+      <div className='flex flex-col gap-1'>
+        <Label className='text-xs'>{t('Model')}</Label>
+        <Input
+          placeholder={t('Model Name')}
+          className='h-8 w-[140px] text-xs'
+          value={filter.modelName}
+          onChange={(e) => onFilterChange({ ...filter, modelName: e.target.value })}
+        />
