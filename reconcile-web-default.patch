@@ -0,0 +1,212 @@
+import { useEffect } from 'react'
+import * as z from 'zod'
+import { useForm } from 'react-hook-form'
+import { zodResolver } from '@hookform/resolvers/zod'
+import { useTranslation } from 'react-i18next'
+import {
+  Form,
+  FormControl,
+  FormDescription,
+  FormField,
+  FormItem,
+  FormLabel,
+  FormMessage,
+} from '@/components/ui/form'
+import { Button } from '@/components/ui/button'
+import { Input } from '@/components/ui/input'
+import { Switch } from '@/components/ui/switch'
+import { SettingsSection } from '../components/settings-section'
+import { useUpdateOption } from '../hooks/use-update-option'
+import type { MaintenanceSettings } from '../types'
+import { useAuthStore } from '@/stores/auth-store'
+import { ROLE } from '@/lib/roles'
+
+const reconcileSchema = z.object({
+  ReconcileEnabled: z.boolean(),
+  ReconcileUsdToCnyRate: z.number().positive(),
+  ReconcileAggregateLagSeconds: z.number().int().nonnegative(),
+  ReconcileMaxUploadSize: z.number().int().positive(),
+  ReconcileTokenTolerance: z.number().int().nonnegative(),
+})
+
+type ReconcileFormValues = z.infer<typeof reconcileSchema>
+
+type Props = {
+  defaultValues: {
+    ReconcileEnabled: boolean
+    ReconcileUsdToCnyRate: number
+    ReconcileAggregateLagSeconds: number
+    ReconcileMaxUploadSize: number
+    ReconcileTokenTolerance: number
+  }
+}
+
+export function ReconcileSection({ defaultValues }: Props) {
+  const { t } = useTranslation()
+  const updateOption = useUpdateOption()
+  const userRole = useAuthStore((state) => state.auth.user?.role ?? 0)
+
+  const form = useForm<ReconcileFormValues>({
+    resolver: zodResolver(reconcileSchema),
+    defaultValues,
+  })
+
+  useEffect(() => {
+    form.reset(defaultValues)
+  }, [defaultValues, form])
+
+  // Only Root can see/operate this section. Gate must come AFTER all hooks
+  // to satisfy the rules-of-hooks invariant (hook count must be stable
+  // across renders of the same component).
+  if (userRole < ROLE.ROOT) return null
+
+  const onSubmit = async (values: ReconcileFormValues) => {
+    const pairs: Array<[string, string]> = [
+      ['ReconcileEnabled', String(values.ReconcileEnabled)],
+      ['ReconcileUsdToCnyRate', String(values.ReconcileUsdToCnyRate)],
+      ['ReconcileAggregateLagSeconds', String(values.ReconcileAggregateLagSeconds)],
+      ['ReconcileMaxUploadSize', String(values.ReconcileMaxUploadSize)],
+      ['ReconcileTokenTolerance', String(values.ReconcileTokenTolerance)],
+    ]
+    for (const [key, value] of pairs) {
+      await updateOption.mutateAsync({ key, value })
+    }
+  }
+
+  return (
+    <SettingsSection
+      title={t('Reconciliation Module')}
+      description={t('Configure supplier billing reconciliation')}
+    >
+      <Form {...form}>
+        <form onSubmit={form.handleSubmit(onSubmit)} className='space-y-6'>
+          <FormField
+            control={form.control}
+            name='ReconcileEnabled'
+            render={({ field }) => (
+              <FormItem className='flex flex-row items-start justify-between rounded-lg border p-4'>
+                <div className='space-y-0.5 pe-4'>
+                  <FormLabel className='text-base'>{t('Enable Reconciliation')}</FormLabel>
+                  <FormDescription>
+                    {t('Shows reconciliation menu in sidebar and starts scheduled aggregation (requires restart)')}
+                  </FormDescription>
+                </div>
+                <FormControl>
+                  <Switch
+                    checked={field.value}
+                    onCheckedChange={field.onChange}
+                  />
+                </FormControl>
+                <FormMessage />
+              </FormItem>
+            )}
+          />
+
+          <FormField
+            control={form.control}
+            name='ReconcileUsdToCnyRate'
+            render={({ field }) => (
+              <FormItem>
+                <FormLabel>{t('USD to CNY Rate')}</FormLabel>
+                <FormControl>
+                  <Input
+                    type='number'
+                    step='0.01'
+                    {...field}
+                    onChange={(e) => field.onChange(parseFloat(e.target.value) || 0)}
+                  />
+                </FormControl>
+                <FormDescription>
+                  {t('FX rate for reconciliation; keep aligned with current rate')}
+                </FormDescription>
+                <FormMessage />
+              </FormItem>
+            )}
+          />
+
+          <FormField
+            control={form.control}
+            name='ReconcileTokenTolerance'
+            render={({ field }) => (
+              <FormItem>
+                <FormLabel>{t('Token Tolerance')}</FormLabel>
+                <FormControl>
+                  <Input
+                    type='number'
+                    step='1'
+                    {...field}
+                    onChange={(e) => field.onChange(parseInt(e.target.value) || 0)}
+                  />
+                </FormControl>
+                <FormDescription>
+                  {t('Allowed absolute token diff for level judgment; 0 = strict equality')}
+                </FormDescription>
+                <FormMessage />
+              </FormItem>
+            )}
+          />
+
+          <FormField
+            control={form.control}
+            name='ReconcileAggregateLagSeconds'
+            render={({ field }) => (
+              <FormItem>
+                <FormLabel>{t('Aggregate Lag Seconds')}</FormLabel>
+                <FormControl>
+                  <Input
+                    type='number'
+                    step='60'
+                    {...field}
+                    onChange={(e) => field.onChange(parseInt(e.target.value) || 0)}
+                  />
+                </FormControl>
+                <FormDescription>
+                  {t('Seconds after a bucket ends before re-aggregating; default 1800')}
+                </FormDescription>
+                <FormMessage />
+              </FormItem>
+            )}
+          />
+
+          <FormField
+            control={form.control}
+            name='ReconcileMaxUploadSize'
+            render={({ field }) => (
+              <FormItem>
+                <FormLabel>{t('Max Upload Size (bytes)')}</FormLabel>
+                <FormControl>
+                  <Input
+                    type='number'
+                    step='1048576'
+                    {...field}
+                    onChange={(e) => field.onChange(parseInt(e.target.value) || 0)}
+                  />
+                </FormControl>
+                <FormDescription>
+                  {t('Max upload size in bytes for bill files; default 10MB (10485760)')}
+                </FormDescription>
+                <FormMessage />
+              </FormItem>
+            )}
+          />
+
+          <Button type='submit' disabled={updateOption.isPending}>
+            {updateOption.isPending ? t('Saving...') : t('Save Reconcile Settings')}
+          </Button>
+        </form>
+      </Form>
+    </SettingsSection>
+  )
+}
+
+// Helper to extract reconcile defaults from settings
+// eslint-disable-next-line react-refresh/only-export-components
+export function extractReconcileDefaults(settings: MaintenanceSettings) {
+  return {
+    ReconcileEnabled: Boolean(settings.ReconcileEnabled),
+    ReconcileUsdToCnyRate: Number(settings.ReconcileUsdToCnyRate) || 7.2,
+    ReconcileAggregateLagSeconds: Number(settings.ReconcileAggregateLagSeconds) || 1800,
+    ReconcileMaxUploadSize: Number(settings.ReconcileMaxUploadSize) || 10485760,
+    ReconcileTokenTolerance: Number(settings.ReconcileTokenTolerance) || 0,
+  }
+}
