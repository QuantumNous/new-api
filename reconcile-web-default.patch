+import { useTranslation } from 'react-i18next'
+import { useSearch } from '@tanstack/react-router'
+import { SectionPageLayout } from '@/components/layout'
+import { Tabs, TabsContent, TabsList, TabsTrigger } from '@/components/ui/tabs'
+import { ReconcileProvider } from './components/reconcile-provider'
+import { DiffTable } from './components/diff-table'
+import { BatchesTable } from './components/batches-table'
+import { SummaryCards } from './components/summary-cards'
+
+type ReconcileTab = 'diff' | 'batches' | 'summary'
+
+function ReconcileContent() {
+  const { t } = useTranslation()
+  const search = useSearch({ strict: false }) as { tab?: ReconcileTab }
+  const activeTab: ReconcileTab = search.tab ?? 'diff'
+
+  return (
+    <SectionPageLayout>
+      <SectionPageLayout.Title>{t('Reconciliation')}</SectionPageLayout.Title>
+      <SectionPageLayout.Description>
+        {t('Manage billing reconciliation between channel suppliers and our logs')}
+      </SectionPageLayout.Description>
+      <SectionPageLayout.Content>
+        <Tabs value={activeTab}>
+          <TabsList>
+            <TabsTrigger value='diff'>{t('Reconcile Detail')}</TabsTrigger>
+            <TabsTrigger value='batches'>{t('Upload Batches')}</TabsTrigger>
+            <TabsTrigger value='summary'>{t('Reconcile Summary')}</TabsTrigger>
+          </TabsList>
+          <div className='mt-4'>
+            <TabsContent value='diff'>
+              <DiffTable />
+            </TabsContent>
+            <TabsContent value='batches'>
+              <BatchesTable />
+            </TabsContent>
+            <TabsContent value='summary'>
+              <SummaryCards />
+            </TabsContent>
+          </div>
+        </Tabs>
+      </SectionPageLayout.Content>
+    </SectionPageLayout>
+  )
+}
+
+export function Reconcile() {
+  return (
+    <ReconcileProvider>
+      <ReconcileContent />
+    </ReconcileProvider>
+  )
+}
