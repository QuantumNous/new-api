@@ -0,0 +1,70 @@
+import type { ColumnDef } from '@tanstack/react-table'
+import { useTranslation } from 'react-i18next'
+import { Badge } from '@/components/ui/badge'
+import { formatTimestampToDate } from '@/lib/format'
+import type { ReconcileBatch } from '../types'
+import { DataTableRowActions } from './data-table-row-actions'
+
+export function useBatchesColumns(): ColumnDef<ReconcileBatch>[] {
+  const { t } = useTranslation()
+
+  return [
+    {
+      accessorKey: 'id',
+      header: 'ID',
+      cell: ({ row }) => <span className='font-mono text-xs'>{row.original.id}</span>,
+    },
+    {
+      accessorKey: 'channel_name',
+      header: t('Channel'),
+      cell: ({ row }) => <span className='text-xs'>{row.original.channel_name}</span>,
+    },
+    {
+      accessorKey: 'file_name',
+      header: t('File Name'),
+      cell: ({ row }) => (
+        <span className='max-w-[200px] truncate text-xs' title={row.original.file_name}>
+          {row.original.file_name}
+        </span>
+      ),
+    },
+    {
+      accessorKey: 'row_count',
+      header: () => <span className='block text-right'>{t('Row Count')}</span>,
+      cell: ({ row }) => (
+        <span className='block text-right font-mono text-xs'>{row.original.row_count}</span>
+      ),
+    },
+    {
+      accessorKey: 'status',
+      header: t('Batch Status'),
+      cell: ({ row }) => {
+        const statusMap: Record<string, { label: string; variant: 'secondary' | 'destructive' | 'default' }> = {
+          done: { label: t('Done'), variant: 'secondary' },
+          parsing: { label: t('Parsing'), variant: 'default' },
+          failed: { label: t('Failed'), variant: 'destructive' },
+        }
+        const s = statusMap[row.original.status] ?? { label: row.original.status, variant: 'default' }
+        return <Badge variant={s.variant}>{s.label}</Badge>
+      },
+    },
+    {
+      accessorKey: 'uploaded_at',
+      header: t('Uploaded At'),
+      cell: ({ row }) => (
+        <span className='whitespace-nowrap text-xs text-muted-foreground'>
+          {formatTimestampToDate(row.original.uploaded_at, 'seconds')}
+        </span>
+      ),
+    },
+    {
+      accessorKey: 'uploader_name',
+      header: t('Uploaded By'),
+      cell: ({ row }) => <span className='text-xs'>{row.original.uploader_name}</span>,
+    },
+    {
+      id: 'actions',
+      cell: ({ row }) => <DataTableRowActions row={row} />,
+    },
+  ]
+}
