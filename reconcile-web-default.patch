@@ -0,0 +1,46 @@
+import React, { useState } from 'react'
+import useDialogState from '@/hooks/use-dialog'
+import type { ReconcileBatch, ReconcileDialogType } from '../types'
+
+type ReconcileContextType = {
+  open: ReconcileDialogType | null
+  setOpen: (str: ReconcileDialogType | null) => void
+  currentBatch: ReconcileBatch | null
+  setCurrentBatch: React.Dispatch<React.SetStateAction<ReconcileBatch | null>>
+  refreshTrigger: number
+  triggerRefresh: () => void
+}
+
+const ReconcileContext = React.createContext<ReconcileContextType | null>(null)
+
+export function ReconcileProvider({ children }: { children: React.ReactNode }) {
+  const [open, setOpen] = useDialogState<ReconcileDialogType>(null)
+  const [currentBatch, setCurrentBatch] = useState<ReconcileBatch | null>(null)
+  const [refreshTrigger, setRefreshTrigger] = useState(0)
+
+  const triggerRefresh = () => setRefreshTrigger((prev) => prev + 1)
+
+  return (
+    <ReconcileContext
+      value={{
+        open,
+        setOpen,
+        currentBatch,
+        setCurrentBatch,
+        refreshTrigger,
+        triggerRefresh,
+      }}
+    >
+      {children}
+    </ReconcileContext>
+  )
+}
+
+// eslint-disable-next-line react-refresh/only-export-components
+export const useReconcile = () => {
+  const ctx = React.useContext(ReconcileContext)
+  if (!ctx) {
+    throw new Error('useReconcile has to be used within <ReconcileProvider>')
+  }
+  return ctx
+}
