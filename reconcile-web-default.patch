+import z from 'zod'
+import { createFileRoute, redirect } from '@tanstack/react-router'
+import { useAuthStore } from '@/stores/auth-store'
+import { ROLE } from '@/lib/roles'
+import { Reconcile } from '@/features/reconcile'
+
+const reconcileSearchSchema = z.object({
+  tab: z.enum(['diff', 'batches', 'summary']).optional().catch('diff'),
+})
+
+export const Route = createFileRoute('/_authenticated/reconcile/')({
+  beforeLoad: () => {
+    const { auth } = useAuthStore.getState()
+
+    if (!auth.user || auth.user.role < ROLE.ADMIN) {
+      throw redirect({
+        to: '/403',
+      })
+    }
+  },
+  validateSearch: reconcileSearchSchema,
+  component: Reconcile,
+})
