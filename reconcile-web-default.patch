index 000000000..8372ccafe
--- /dev/null
+++ b/web/default/src/features/reconcile/api.ts
@@ -0,0 +1,94 @@
+import { api } from '@/lib/api'
+import type {
+  ReconcileBatch,
+  DiffRow,
+  SummaryRow,
+  ReaggregateRequest,
+} from './types'
+
+type ApiResponse<T = unknown> = {
+  success: boolean
+  message: string
+  data?: T
+  total?: number
+}
+
+type PaginatedResponse<T> = ApiResponse<T[]> & { total: number }
+
+export async function uploadReconcileBill(
+  channelId: number,
+  file: File
+): Promise<ApiResponse<{ batch_id: string; row_count: number; warning?: string }>> {
+  const form = new FormData()
+  form.append('channel_id', String(channelId))
+  form.append('file', file)
+  const res = await api.post('/api/reconcile/admin/upload', form, {
+    headers: { 'Content-Type': 'multipart/form-data' },
+  })
+  return res.data
+}
+
+export async function listReconcileBatches(params: {
+  channel_id?: number
+  status?: string
+  page?: number
+  page_size?: number
+}): Promise<PaginatedResponse<ReconcileBatch>> {
+  const res = await api.get('/api/reconcile/admin/batches', { params })
+  return res.data
+}
+
+export async function deleteReconcileBatch(
+  id: number
+): Promise<ApiResponse> {
+  const res = await api.delete(`/api/reconcile/admin/batches/${id}`)
+  return res.data
+}
+
+export async function queryReconcileDiff(params: {
+  channel_id: number
+  from: number
+  to: number
+  model_name?: string
+  only_diff?: boolean
+  tolerance_amount?: number
+  tolerance_pct?: number
+  page?: number
+  page_size?: number
+}): Promise<PaginatedResponse<DiffRow>> {
+  const res = await api.get('/api/reconcile/admin/diff', { params })
+  return res.data
+}
+
+export async function queryReconcileSummary(params: {
+  channel_id: number
+  from: number
+  to: number
+  model_name?: string
+}): Promise<ApiResponse<SummaryRow[]>> {
+  const res = await api.get('/api/reconcile/admin/summary', { params })
+  return res.data
+}
+
+export async function triggerReaggregate(
+  req: ReaggregateRequest
+): Promise<ApiResponse<{ processed_buckets: number; failed_buckets: number }>> {
+  const res = await api.post('/api/reconcile/admin/reaggregate', req)
+  return res.data
+}
+
+export function getExportUrl(params: {
+  channel_id: number
+  month: string
+  format?: string
+  only_diff?: boolean
+  model_name?: string
+}): string {
+  const qs = new URLSearchParams()
+  qs.set('channel_id', String(params.channel_id))
+  qs.set('month', params.month)
+  if (params.format) qs.set('format', params.format)
+  if (params.only_diff) qs.set('only_diff', 'true')
+  if (params.model_name) qs.set('model_name', params.model_name)
+  return `/api/reconcile/admin/export?${qs.toString()}`
+}
