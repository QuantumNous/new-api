+/* eslint-disable react-refresh/only-export-components */
+// File mixes the LevelBadge component with the useDiffColumns hook by design;
+// fast refresh works fine in practice for column hooks here.
+import type { ColumnDef } from '@tanstack/react-table'
+import { useTranslation } from 'react-i18next'
+import { Badge } from '@/components/ui/badge'
+import { cn } from '@/lib/utils'
+import type { DiffRow } from '../types'
+import { DIFF_LEVEL_VARIANT, TOKEN_TYPE_CN } from '../constants'
+
+function LevelBadge({ level }: { level: string }) {
+  const { t } = useTranslation()
+  const labelMap: Record<string, string> = {
+    ok: t('OK'),
+    low: t('Low'),
+    high: t('High'),
+    missing_ours: t('Missing Ours'),
+    missing_supplier: t('Missing Supplier'),
+  }
+  const variant = DIFF_LEVEL_VARIANT[level] ?? 'default'
+  return (
+    <Badge
+      variant={variant as 'secondary' | 'outline' | 'destructive' | 'default'}
+      className={cn(level === 'low' && 'bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-200')}
+    >
+      {labelMap[level] ?? level}
+    </Badge>
+  )
+}
+
+export function useDiffColumns(): ColumnDef<DiffRow>[] {
+  const { t } = useTranslation()
+
+  return [
+    {
+      accessorKey: 'hour_label',
+      header: t('Time Range'),
+      cell: ({ row }) => (
+        <span className='whitespace-nowrap text-xs'>{row.original.hour_label}</span>
+      ),
+    },
+    {
+      accessorKey: 'model_name',
+      header: t('Model'),
+      cell: ({ row }) => (
+        <span className='max-w-[160px] truncate font-mono text-xs'>{row.original.model_name}</span>
+      ),
+    },
+    {
+      accessorKey: 'token_type',
+      header: t('Config Desc'),
+      cell: ({ row }) => (
+        <span className='text-xs'>
+          {TOKEN_TYPE_CN[row.original.token_type] ?? row.original.token_type}
+        </span>
+      ),
+    },
+    {
+      id: 'ours_tokens',
+      header: () => <span className='block text-right'>{t('Our Tokens')}</span>,
+      cell: ({ row }) => (
+        <span className='block text-right font-mono text-xs'>
+          {row.original.ours.tokens.toLocaleString()}
+        </span>
+      ),
+    },
+    {
+      id: 'ours_amount',
+      header: () => <span className='block text-right'>{t('Our Amount')}</span>,
+      cell: ({ row }) => (
+        <span className='block text-right font-mono text-xs'>
+          ¥{row.original.ours.amount_cny.toFixed(6)}
+        </span>
+      ),
+    },
+    {
+      id: 'supplier_tokens',
+      header: () => <span className='block text-right'>{t('Supplier Tokens')}</span>,
+      cell: ({ row }) => (
+        <span className='block text-right font-mono text-xs'>
+          {row.original.supplier.tokens.toLocaleString()}
+        </span>
+      ),
+    },
+    {
+      id: 'supplier_amount',
+      header: () => <span className='block text-right'>{t('Supplier Amount')}</span>,
+      cell: ({ row }) => (
+        <span className='block text-right font-mono text-xs'>
+          ¥{row.original.supplier.amount_cny.toFixed(6)}
+        </span>
+      ),
+    },
+    {
+      id: 'amount_diff',
+      header: () => <span className='block text-right'>{t('Amount Diff (¥)')}</span>,
+      cell: ({ row }) => {
+        const diff = row.original.diff.amount_diff
+        return (
+          <span
+            className={cn(
+              'block text-right font-mono text-xs',
+              Math.abs(diff) > 0.001 && 'text-red-600 dark:text-red-400'
+            )}
+          >
+            {diff >= 0 ? '+' : ''}{diff.toFixed(6)}
+          </span>
+        )
+      },
+    },
+    {
+      id: 'diff_pct',
+      header: () => <span className='block text-right'>{t('Diff Rate (%)')}</span>,
+      cell: ({ row }) => (
+        <span className='block text-right font-mono text-xs'>
+          {row.original.diff.amount_diff_pct.toFixed(2)}%
+        </span>
+      ),
+    },
+    {
+      id: 'level',
+      header: t('Diff Level'),
+      cell: ({ row }) => <LevelBadge level={row.original.diff.level} />,
+    },
+    {
+      accessorKey: 'supplier.site',
+      header: t('Site'),
+      cell: ({ row }) => (
+        <span className='text-xs text-muted-foreground'>{row.original.supplier.site}</span>
+      ),
+    },
+    {
+      id: 'note',
+      header: 'Note',
+      cell: ({ row }) =>
+        row.original.ours.note ? (
+          <span className='text-xs text-muted-foreground'>{row.original.ours.note}</span>
+        ) : null,
+    },
+  ]
+}
