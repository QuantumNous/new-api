# web/classic frontend environment variables
# Copy to .env and uncomment lines you want to override.

# Backend API base URL (leave empty for same-origin / reverse-proxy setups).
# VITE_REACT_APP_SERVER_URL=https://your-api.example.com

# GitHub repo used for update checks and release links.
# Defaults to Calcium-Ion/new-api when unset.
# Set this to your fork if you host a customised build.
# VITE_UPDATE_REPO=your-org/new-api
