# Frontend build-time environment variables (Rsbuild, prefix VITE_).
# Copy to .env.local and fill in as needed. All are optional.

# Backend API base URL for local dev proxy.
# VITE_REACT_APP_SERVER_URL=http://localhost:3000

# --- Google Ads / GA4 conversion tracking (optional) ---
# When VITE_GADS_CONVERSION_ID is unset, all tracking is a no-op.
# gtag account id from Google Ads, e.g. AW-XXXXXXXXXX
# VITE_GADS_CONVERSION_ID=
# Full send_to for the signup conversion (copy verbatim from the Google Ads
# event snippet), e.g. AW-XXXXXXXXXX/AbCdEfGhIj
# VITE_GADS_SIGNUP_SEND_TO=
