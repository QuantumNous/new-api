# Rsbuild dev server for local / demo stacks (docker-compose.dev.yml).
FROM node:22-bookworm-slim

RUN apt-get update \
  && apt-get install -y --no-install-recommends ca-certificates \
  && rm -rf /var/lib/apt/lists/* \
  && corepack enable \
  && corepack prepare pnpm@10.28.0 --activate

WORKDIR /app

COPY package.json pnpm-lock.yaml ./
RUN pnpm install --frozen-lockfile

COPY docker-dev-entrypoint.sh /usr/local/bin/docker-dev-entrypoint.sh
RUN chmod +x /usr/local/bin/docker-dev-entrypoint.sh

EXPOSE 3001

ENV VITE_REACT_APP_SERVER_URL=http://new-api:3000

ENTRYPOINT ["/usr/local/bin/docker-dev-entrypoint.sh"]
